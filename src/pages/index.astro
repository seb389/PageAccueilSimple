---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n';

const tr = useTranslations('fr');
---
<Base title={tr.title_home} lang="fr">

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <nav class="lang-switcher">
      <span class="lang-active">{tr.lang_self}</span>
      <span class="lang-sep">·</span>
      <a href={tr.alt_home}>{tr.lang_other}</a>
    </nav>
  </header>

  <main class="spread">
    <div class="home-top">
      <h1 class="wordmark">LACET</h1>
      <div class="surligne">
        {tr.tagline_left}<span class="rule"></span>{tr.tagline_right}
      </div>
      <div class="status">{tr.status}</div>
    </div>

    <div class="cta">
      <p class="cta-prompt">{tr.survey_cta_prompt}</p>
      <a href={tr.survey_cta_href} class="cta-button">
        <span>{tr.survey_cta_button}</span>
        <span class="cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>

    <div class="contact">
      <span class="label">{tr.contact_label}</span>
      <a href="mailto:info@lacet.ca">info@lacet.ca</a>
    </div>
  </main>

  <Footer lang="fr" />

</Base>
