<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lacet · Quebec</title>
<meta name="description" content="Lacet — Atelier de vélo, Quebec." />
<meta name="robots" content="index, follow" />
<meta property="og:title" content="Lacet · Quebec" />
<meta property="og:description" content="Lacet — Atelier de vélo, Quebec." />
<meta property="og:type" content="website" />
<meta name="theme-color" content="#0f0f0f" />
<style>
  /* Inter — latin-ext */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  /* Inter — latin */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
  /* Inter — latin-ext 700 */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  /* Inter — latin 700 */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }

  :root {
    --charbon: #0f0f0f;
    --craie:   #f4f1ec;
    --cuivre:  #b66a3e;
    --fumee:   #8a8680;
    --line:    rgba(244, 241, 236, 0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--charbon);
    color: var(--craie);
    font-family: "Inter", "Helvetica Neue", -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 32px;
    animation: pageIn 1.2s ease-out both;
  }

  @keyframes pageIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .corner {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
  }
  .corner .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cuivre);
  }

  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 40px 16px;
  }

  .wordmark {
    font-weight: 700;
    letter-spacing: 0.22em;
    font-size: clamp(56px, 14vw, 148px);
    line-height: 1;
    color: var(--craie);
    animation: wordmarkIn 1.4s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes wordmarkIn {
    from { opacity: 0; letter-spacing: 0.5em; }
    to   { opacity: 1; letter-spacing: 0.22em; }
  }

  .surligne {
    margin-top: 22px;
    font-size: clamp(10px, 1.2vw, 12px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.8s ease-out both;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .rule {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--cuivre);
    margin: 0 14px;
    vertical-align: middle;
  }

  .status {
    margin-top: 72px;
    font-size: clamp(11px, 1.2vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 1.1s ease-out both;
  }
  .status::before,
  .status::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }

  .contact {
    margin-top: 40px;
    font-size: clamp(12px, 1.4vw, 14px);
    color: var(--fumee);
    letter-spacing: 0.04em;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .contact .label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .contact a {
    color: var(--craie);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    letter-spacing: 0.04em;
    transition: color 0.25s ease, border-color 0.25s ease;
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 400;
  }
  .contact a:hover,
  .contact a:focus {
    color: var(--cuivre);
    border-color: var(--cuivre);
    outline: none;
  }

  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    body { padding: 20px; }
    footer { flex-direction: column; gap: 8px; }
    .status { margin-top: 48px; }
    .status::before,
    .status::after { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<header class="corner">
  <span class="dot"></span>
  <span>Québec</span>
</header>

<main>
  <h1 class="wordmark">LACET</h1>

  <div class="surligne">
    Location<span class="rule"></span>Vélo
  </div>

  <div class="status">Prochainement</div>

  <div class="contact">
    <span class="label">Pour information</span>
    <a href="mailto:info@lacet.ca">info@lacet.ca</a>
  </div>
</main>

<footer>
  <span>© 2026 Lacet</span>
  <span>lacet.ca</span>
</footer>

</body>
</html>
