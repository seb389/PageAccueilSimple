---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';
const tr = useTranslations('en');
---
<Base title={tr.title_home} lang="en">

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <nav class="lang-switcher">
      <a href={tr.alt_home}>{tr.lang_other}</a>
      <span class="lang-sep">·</span>
      <span class="lang-active">{tr.lang_self}</span>
    </nav>
  </header>

  <main class="centered">
    <h1 class="wordmark">LACET</h1>
    <div class="surligne">
      {tr.tagline_left}<span class="rule"></span>{tr.tagline_right}
    </div>
    <div class="status">{tr.status}</div>
    <div class="contact">
      <span class="label">{tr.contact_label}</span>
      <a href="mailto:info@lacet.ca">info@lacet.ca</a>
    </div>
  </main>

  <footer>
    <span>{tr.footer_copy}</span>
    <span>{tr.footer_domain}</span>
  </footer>

</Base>
