---
import Base from '../../layouts/Base.astro';
import SurveyForm from '../../components/SurveyForm.astro';
import TeaserSondage from '../../components/TeaserSondage.astro';
import Footer from '../../components/Footer.astro';
import { useTranslations } from '../../i18n';
import { isSurveyLaunched } from '../../launch';

export const prerender = false;

const tr = useTranslations('en');

const preview = new URL(Astro.request.url).searchParams.get('preview');
const showSurvey = preview === 'survey'
  ? true
  : preview === 'teaser'
    ? false
    : isSurveyLaunched();
---
<Base
  title={tr.title_sondage}
  lang="en"
  ogTitle="Lacet · Quebec cyclist survey"
  ogDescription="Help us build a Quebec-based premium road bike rental service. 3-minute survey — your voice counts."
  ogImage="https://www.lacet.ca/og-image-sondage-v2.jpg"
>

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <div class="corner-right">
      <a href={tr.back_href} class="back">{tr.back}</a>
      <nav class="lang-switcher">
        <a href={tr.alt_sondage}>{tr.lang_other}</a>
        <span class="lang-sep">·</span>
        <span class="lang-active">{tr.lang_self}</span>
      </nav>
    </div>
  </header>

  <main>
    {showSurvey ? <SurveyForm lang="en" /> : <TeaserSondage lang="en" />}
  </main>

  <Footer lang="en" />

</Base>
