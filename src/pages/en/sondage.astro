---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n';
const tr = useTranslations('en');
const FORM_URL = 'https://docs.google.com/forms/d/e/1FAIpQLSfegqGPewOsPUPblSO8QJVq7rGGvE5GtnKkwOLm7_gR_6Ke0w/viewform';
---
<Base title={tr.title_sondage} lang="en">

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <div class="corner-right">
      <a href={tr.back_href} class="back">{tr.back}</a>
      <nav class="lang-switcher">
        <a href={tr.alt_sondage}>{tr.lang_other}</a>
        <span class="lang-sep">·</span>
        <span class="lang-active">{tr.lang_self}</span>
      </nav>
    </div>
  </header>

  <main>
    <div class="page-title">{tr.sondage_heading}</div>
    <div class="page-sub">
      {tr.tagline_left}<span style="display:inline-block;width:32px;height:1px;background:var(--cuivre);margin:0 10px;vertical-align:middle;"></span>{tr.tagline_right}
    </div>
    <div class="form-wrapper">
      <iframe
        src={`${FORM_URL}?embedded=true`}
        title={tr.sondage_heading}
        loading="lazy"
      >
        Loading…
      </iframe>
    </div>
    <div class="form-link">
      <a href={FORM_URL} target="_blank" rel="noopener noreferrer">
        {tr.form_link}
      </a>
    </div>
  </main>

  <footer>
    <span>{tr.footer_copy}</span>
    <span>{tr.footer_domain}</span>
  </footer>

</Base>
