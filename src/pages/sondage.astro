<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Lacet · Sondage</title>
<meta name="description" content="Lacet — Sondage." />
<meta name="theme-color" content="#0f0f0f" />
<style>
  /* Inter — latin-ext */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  /* Inter — latin */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
  /* Inter — latin-ext 700 */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  /* Inter — latin 700 */
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }

  :root {
    --charbon: #0f0f0f;
    --craie:   #f4f1ec;
    --cuivre:  #b66a3e;
    --fumee:   #8a8680;
    --line:    rgba(244, 241, 236, 0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--charbon);
    color: var(--craie);
    font-family: "Inter", "Helvetica Neue", -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 32px;
    animation: pageIn 1.2s ease-out both;
  }

  @keyframes pageIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Header */
  .corner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .corner-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
  }
  .corner-left .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cuivre);
  }

  .back {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .back:hover { color: var(--craie); }

  /* Main */
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 32px 16px 24px;
  }

  .page-title {
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .page-title::before,
  .page-title::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }

  .page-sub {
    margin-top: 10px;
    font-size: clamp(10px, 1.2vw, 11px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.5s ease-out both;
  }

  .form-wrapper {
    margin-top: 24px;
    flex: 1;
    width: 100%;
    max-width: 860px;
    border: 1px solid var(--line);
    animation: fadeUp 1.2s 0.7s ease-out both;
    display: flex;
    flex-direction: column;
  }

  .form-wrapper iframe {
    display: block;
    width: 100%;
    flex: 1;
    min-height: calc(100vh - 220px);
    border: none;
    background: var(--charbon);
  }

  .form-link {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    animation: fadeUp 1.2s 0.9s ease-out both;
  }
  .form-link a {
    color: var(--fumee);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .form-link a:hover {
    color: var(--cuivre);
    border-color: var(--cuivre);
  }

  /* Footer */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    body { padding: 20px; }
    footer { flex-direction: column; gap: 8px; }
    .page-title::before,
    .page-title::after { display: none; }
    .form-wrapper iframe { min-height: calc(100vh - 200px); }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>

<header class="corner">
  <div class="corner-left">
    <span class="dot"></span>
    <span>Québec</span>
  </div>
  <a href="/" class="back">← Accueil</a>
</header>

<main>
  <div class="page-title">Sondage</div>
  <div class="page-sub">Location<span style="display:inline-block;width:32px;height:1px;background:var(--cuivre);margin:0 10px;vertical-align:middle;"></span>Vélo</div>

  <div class="form-wrapper">
    <!-- Remplacer l'attribut src par l'URL de votre Google Form -->
    <!-- Format : https://docs.google.com/forms/d/e/VOTRE_ID/viewform?embedded=true -->
    <iframe
      src="https://docs.google.com/forms/d/e/1FAIpQLSfegqGPewOsPUPblSO8QJVq7rGGvE5GtnKkwOLm7_gR_6Ke0w/viewform?embedded=true"
      title="Sondage Lacet"
      loading="lazy"
    >
      Chargement du formulaire…
    </iframe>
  </div>

  <div class="form-link">
    <a href="https://docs.google.com/forms/d/e/1FAIpQLSfegqGPewOsPUPblSO8QJVq7rGGvE5GtnKkwOLm7_gR_6Ke0w/viewform" target="_blank" rel="noopener noreferrer">
      Ouvrir le formulaire dans un nouvel onglet
    </a>
  </div>
</main>

<footer>
  <span>© 2026 Lacet</span>
  <span>lacet.ca</span>
</footer>

</body>
</html>
