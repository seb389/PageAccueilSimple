---
import Base from '../layouts/Base.astro';
import SurveyForm from '../components/SurveyForm.astro';
import TeaserSondage from '../components/TeaserSondage.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n';
import { isSurveyLaunched } from '../launch';

export const prerender = false;

const tr = useTranslations('fr');

// Conditional render: teaser before launch, survey after.
// `?preview=teaser` or `?preview=survey` lets us preview either mode without changing the date.
const preview = new URL(Astro.request.url).searchParams.get('preview');
const showSurvey = preview === 'survey'
  ? true
  : preview === 'teaser'
    ? false
    : isSurveyLaunched();
---
<Base
  title={tr.title_sondage}
  lang="fr"
  ogTitle="Lacet · Sondage cyclistes du Québec"
  ogDescription="Aidez-nous à bâtir un service québécois de location de vélos de route haut de gamme. Sondage de 3 minutes — votre voix compte."
  ogImage="https://www.lacet.ca/og-image-sondage-v2.jpg"
>

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <div class="corner-right">
      <a href={tr.back_href} class="back">{tr.back}</a>
      <nav class="lang-switcher">
        <span class="lang-active">{tr.lang_self}</span>
        <span class="lang-sep">·</span>
        <a href={tr.alt_sondage}>{tr.lang_other}</a>
      </nav>
    </div>
  </header>

  <main>
    {showSurvey ? <SurveyForm lang="fr" /> : <TeaserSondage lang="fr" />}
  </main>

  <Footer lang="fr" />

</Base>
