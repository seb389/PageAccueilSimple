---
import Base from '../../layouts/Base.astro';
import { env } from 'cloudflare:workers';
import { survey } from '../../survey';
import { TEST_RESPONSES, type SurveyResponse } from '../../admin/test-data';

export const prerender = false;

const content = survey.fr;
const url = new URL(Astro.request.url);
const isTest = url.searchParams.get('mode') === 'test';

// ─── Helpers ─────────────────────────────────────────────────────────
function labelFor(qKey: string, value: string | number): string {
  for (const section of content.sections) {
    for (const q of section.questions) {
      if (q.key === qKey) {
        if (q.type === 'radio' || q.type === 'checkbox') {
          return q.options.find(o => o.value === String(value))?.label ?? String(value);
        }
        if (q.type === 'scale') return String(value);
      }
    }
  }
  return String(value);
}
function matrixRowLabel(rowKey: string): string {
  for (const section of content.sections) {
    for (const q of section.questions) {
      if (q.type === 'matrix') {
        const row = q.rows.find(r => r.key === rowKey);
        if (row) return row.label;
      }
    }
  }
  return rowKey;
}
function pct(n: number, total: number): string {
  if (total <= 0) return '0%';
  return Math.round((n / total) * 100) + '%';
}
function fmtDate(iso: string): string {
  if (!iso) return '';
  const d = new Date(iso.replace(' ', 'T') + 'Z');
  return d.toLocaleString('fr-CA', { dateStyle: 'short', timeStyle: 'short' });
}
function maxN(arr: { n: number }[]): number {
  let m = 0;
  for (const x of arr) if (x.n > m) m = x.n;
  return m;
}
function widthPct(n: number, max: number): number {
  return max > 0 ? (n / max) * 100 : 0;
}

// ─── Aggregation helpers (work on response arrays) ───────────────────
function distSingle(rows: SurveyResponse[], field: keyof SurveyResponse): { value: string; n: number }[] {
  const counts = new Map<string, number>();
  for (const r of rows) {
    const v = String(r[field] ?? '');
    if (v) counts.set(v, (counts.get(v) ?? 0) + 1);
  }
  return Array.from(counts.entries()).map(([value, n]) => ({ value, n }));
}
function distMulti(rows: SurveyResponse[], field: keyof SurveyResponse): { value: string; n: number }[] {
  const counts = new Map<string, number>();
  for (const r of rows) {
    let arr: string[] = [];
    try { arr = JSON.parse(String(r[field] ?? '[]')); } catch {}
    for (const v of arr) counts.set(v, (counts.get(v) ?? 0) + 1);
  }
  return Array.from(counts.entries()).map(([value, n]) => ({ value, n }));
}
function orderByOptions(qKey: string, dist: { value: string; n: number }[]): { value: string; n: number }[] {
  for (const section of content.sections) {
    for (const q of section.questions) {
      if (q.key === qKey && (q.type === 'radio' || q.type === 'checkbox')) {
        const map = new Map(dist.map(d => [d.value, d.n]));
        return q.options.map(o => ({ value: o.value, n: map.get(o.value) ?? 0 }));
      }
    }
  }
  return dist;
}

// Cross-analyses
function avgInterestBy(rows: SurveyResponse[], field: keyof SurveyResponse): { value: string; avg: number; n: number }[] {
  const groups = new Map<string, number[]>();
  for (const r of rows) {
    const k = String(r[field] ?? '');
    if (!k) continue;
    if (!groups.has(k)) groups.set(k, []);
    groups.get(k)!.push(r.interest);
  }
  return Array.from(groups.entries()).map(([value, scores]) => ({
    value,
    avg: scores.length > 0 ? scores.reduce((a, b) => a + b, 0) / scores.length : 0,
    n: scores.length,
  }));
}
function pctMatchingBy(
  rows: SurveyResponse[],
  field: keyof SurveyResponse,
  pred: (r: SurveyResponse) => boolean,
): { value: string; matches: number; n: number; pct: number }[] {
  const groups = new Map<string, { matches: number; total: number }>();
  for (const r of rows) {
    const k = String(r[field] ?? '');
    if (!k) continue;
    if (!groups.has(k)) groups.set(k, { matches: 0, total: 0 });
    const g = groups.get(k)!;
    g.total++;
    if (pred(r)) g.matches++;
  }
  return Array.from(groups.entries()).map(([value, g]) => ({
    value,
    matches: g.matches,
    n: g.total,
    pct: g.total > 0 ? (g.matches / g.total) * 100 : 0,
  }));
}
function orderCross<T extends { value: string }>(qKey: string, items: T[]): T[] {
  for (const section of content.sections) {
    for (const q of section.questions) {
      if (q.key === qKey && (q.type === 'radio' || q.type === 'checkbox')) {
        const order = q.options.map(o => o.value);
        const map = new Map(items.map(i => [i.value, i]));
        return order.map(v => map.get(v)).filter((x): x is T => x !== undefined);
      }
    }
  }
  return items;
}

// ─── Constants ───────────────────────────────────────────────────────
const PRICE_TARGETS: { [k: string]: string } = {
  price_week: '500_700',
  price_month: '1000_1500',
  price_season: '2500_3500',
};
const PRICE_TITLES: { [k: string]: string } = {
  price_week: 'Semaine',
  price_month: 'Mois',
  price_season: 'Saison',
};
const PROFILE_TITLES: { [k: string]: string } = {
  age: "Tranche d'âge",
  region: 'Région',
  practice: 'Pratique du vélo',
  km_season: 'Kilométrage par saison',
  bike_value: 'Valeur du vélo actuel',
};

const PROFILE_KEYS  = ['age', 'region', 'practice', 'km_season', 'bike_value'] as const;
const PRICE_KEYS    = ['price_week', 'price_month', 'price_season'] as const;
const SERVICES_ROWS = ['val_delivery','val_bikefit','val_maintenance','val_insurance','val_exchange','val_coaching','val_equipment','val_purchase','val_routes'] as const;

// ─── Load data ───────────────────────────────────────────────────────
let allResponses: SurveyResponse[] = [];

if (isTest) {
  allResponses = TEST_RESPONSES;
} else {
  try {
    const r = await env.DB
      .prepare('SELECT * FROM survey_responses ORDER BY created_at DESC')
      .all<SurveyResponse>();
    allResponses = r.results ?? [];
  } catch (err) {
    console.error('[admin/survey] query failed', err);
  }
}

// ─── Compute aggregates ──────────────────────────────────────────────
const total = allResponses.length;

const byLang = { fr: 0, en: 0 };
for (const r of allResponses) {
  if (r.lang === 'fr') byLang.fr++;
  else if (r.lang === 'en') byLang.en++;
}

let highCount = 0;
let interestSum = 0;
for (const r of allResponses) {
  if (r.interest >= 7) highCount++;
  interestSum += r.interest;
}
const interestAvg = total > 0 ? interestSum / total : 0;

const intCounts: { [k: number]: number } = {};
for (const r of allResponses) intCounts[r.interest] = (intCounts[r.interest] ?? 0) + 1;
const interestDist = Array.from({ length: 10 }, (_, i) => ({ value: i + 1, n: intCounts[i + 1] ?? 0 }));

// ─── NPS (Net Promoter Score) ─────────────────────────────────────────
// Promoteurs : 9-10, Passifs : 7-8, Détracteurs : 0-6
// NPS = % promoteurs − % détracteurs
let npsSum = 0;
let npsCount = 0;
let promoters = 0;
let passives = 0;
let detractors = 0;
const npsCounts: { [k: number]: number } = {};
for (const r of allResponses) {
  if (typeof r.nps === 'number') {
    npsCounts[r.nps] = (npsCounts[r.nps] ?? 0) + 1;
    npsSum += r.nps;
    npsCount++;
    if (r.nps >= 9) promoters++;
    else if (r.nps >= 7) passives++;
    else detractors++;
  }
}
const npsAvg = npsCount > 0 ? npsSum / npsCount : 0;
const npsScore = npsCount > 0
  ? Math.round((promoters / npsCount) * 100) - Math.round((detractors / npsCount) * 100)
  : 0;
const npsDist = Array.from({ length: 11 }, (_, i) => ({ value: i, n: npsCounts[i] ?? 0 }));

const profileDists: { [k: string]: { value: string; n: number }[] } = {};
for (const k of PROFILE_KEYS) profileDists[k] = orderByOptions(k, distSingle(allResponses, k));

const priceDists: { [k: string]: { value: string; n: number }[] } = {};
for (const k of PRICE_KEYS) priceDists[k] = orderByOptions(k, distSingle(allResponses, k));

const durationDist = orderByOptions('duration', distSingle(allResponses, 'duration'));
const multiBikeType = orderByOptions('bike_type', distMulti(allResponses, 'bike_type'));
const multiContexts = orderByOptions('contexts', distMulti(allResponses, 'contexts'));

const topService = orderByOptions('top_service', distSingle(allResponses, 'top_service'))
  .filter(x => x.n > 0).sort((a, b) => b.n - a.n);
const mainConcern = orderByOptions('main_concern', distSingle(allResponses, 'main_concern'))
  .filter(x => x.n > 0).sort((a, b) => b.n - a.n);

const servicesEssential = SERVICES_ROWS
  .map(row => ({ key: row, n: allResponses.filter(r => r[row] === 'essential').length }))
  .sort((a, b) => b.n - a.n);

// Cross-analyses
const crossInterestByPractice = orderCross('practice', avgInterestBy(allResponses, 'practice'));
const crossInterestByBikeValue = orderCross('bike_value', avgInterestBy(allResponses, 'bike_value'));
const crossHighInterestByRegion = orderCross(
  'region',
  pctMatchingBy(allResponses, 'region', r => r.interest >= 7),
);
const crossPriceTargetByPractice = orderCross(
  'practice',
  pctMatchingBy(allResponses, 'practice', r => r.price_week === '500_700' || r.price_week === '700_1000' || r.price_week === 'over_1000'),
);

// Pagination
const PAGE_SIZE = 20;
const totalPages = Math.max(1, Math.ceil(allResponses.length / PAGE_SIZE));
const requestedPage = parseInt(url.searchParams.get('page') ?? '1', 10) || 1;
const currentPage = Math.min(Math.max(1, requestedPage), totalPages);
const pageOffset = (currentPage - 1) * PAGE_SIZE;
const pageResponses = allResponses.slice(pageOffset, pageOffset + PAGE_SIZE);
const pageStart = total > 0 ? pageOffset + 1 : 0;
const pageEnd = pageOffset + pageResponses.length;

function pageUrl(p: number): string {
  const params = new URLSearchParams();
  if (isTest) params.set('mode', 'test');
  if (p > 1) params.set('page', String(p));
  const qs = params.toString();
  return '/admin/survey' + (qs ? '?' + qs : '') + '#responses';
}
function detailUrl(id: number): string {
  return isTest ? `/admin/survey/${id}?mode=test` : `/admin/survey/${id}`;
}
function previewComment(c: string | null): string {
  if (!c) return '';
  return c.length > 60 ? c.slice(0, 57) + '…' : c;
}

// Pre-compute max per distribution
const maxes = {
  interest:           maxN(interestDist),
  nps:                maxN(npsDist),
  duration:           maxN(durationDist),
  bikeType:           maxN(multiBikeType),
  contexts:           maxN(multiContexts),
  topService:         maxN(topService),
  mainConcern:        maxN(mainConcern),
  servicesEssential:  maxN(servicesEssential),
};
const profileMaxes: { [k: string]: number } = {};
for (const k of PROFILE_KEYS) profileMaxes[k] = maxN(profileDists[k] ?? []);
const priceMaxes: { [k: string]: number } = {};
for (const k of PRICE_KEYS) priceMaxes[k] = maxN(priceDists[k] ?? []);

const userEmail = Astro.request.headers.get('cf-access-authenticated-user-email') ?? 'admin';
---
<Base title="LACET · Admin" lang="fr" theme="light">

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>Admin · Lacet</span>
    </div>
    <div class="corner-right">
      <span class="admin-user">{userEmail}</span>
      <a href="/cdn-cgi/access/logout?returnTo=https://lacet.ca/" class="back">Logout</a>
    </div>
  </header>

  <main>
    <div class="admin-page">

      <nav class="admin-nav">
        <a href="/admin/survey" class="is-active">Sondage</a>
        <a href="/admin/contest">Concours</a>
      </nav>

      <div class="mode-toggle">
        <a href="/admin/survey" class={isTest ? '' : 'is-active'}>Données réelles</a>
        <a href="/admin/survey?mode=test" class={isTest ? 'is-active' : ''}>Données test</a>
      </div>

      {isTest && (
        <div class="test-banner">
          <strong>Mode test</strong> — vous regardez {TEST_RESPONSES.length} réponses fictives, pas les vraies données.
        </div>
      )}

      <section class="admin-section">
        <h1 class="admin-title">Sondage</h1>
        <div class="admin-stats">
          <div class="stat">
            <div class="stat-value">{total}</div>
            <div class="stat-label">Réponses</div>
          </div>
          <div class="stat">
            <div class="stat-value">{byLang.fr}</div>
            <div class="stat-label">Français</div>
          </div>
          <div class="stat">
            <div class="stat-value">{byLang.en}</div>
            <div class="stat-label">English</div>
          </div>
          <div class="stat">
            <div class="stat-value">{pct(highCount, total)}</div>
            <div class="stat-label">Intérêt ≥ 7/10</div>
          </div>
        </div>
        <div class="admin-actions">
          <a href="/api/admin/export-csv" class="admin-button" download>
            <span>CSV simple</span>
            <span aria-hidden="true">↓</span>
          </a>
          <a href="/api/admin/export-csv?format=expanded" class="admin-button" download title="Multi-choix éclatés en colonnes booléennes — idéal pour Excel">
            <span>CSV éclaté (Excel)</span>
            <span aria-hidden="true">↓</span>
          </a>
        </div>
      </section>

      {total === 0 && (
        <p class="admin-empty">Aucune réponse pour l'instant. Les analyses apparaîtront dès la première soumission.</p>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Validation de la demande</h2>
          <p class="admin-meta">Score moyen : <strong>{interestAvg.toFixed(1)} / 10</strong> · {highCount} sur {total} ont un intérêt fort (≥ 7)</p>
          <div class="dist">
            {interestDist.map(item => (
              <div class="dist-row">
                <span class="dist-label">{item.value}/10</span>
                <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.interest)}%`}></div></div>
                <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
              </div>
            ))}
          </div>
        </section>
      )}

      {total > 0 && npsCount > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Recommandation (NPS)</h2>
          <p class="admin-meta">
            Score moyen : <strong>{npsAvg.toFixed(1)} / 10</strong> ·
            <strong class={`nps-score ${npsScore >= 50 ? 'is-excellent' : npsScore >= 0 ? 'is-good' : 'is-poor'}`}>NPS&nbsp;: {npsScore > 0 ? '+' : ''}{npsScore}</strong>
          </p>
          <div class="nps-segments">
            <div class="nps-segment is-promoter">
              <div class="nps-segment-pct">{npsCount > 0 ? Math.round((promoters / npsCount) * 100) : 0}%</div>
              <div class="nps-segment-label">Promoteurs (9-10)</div>
              <div class="nps-segment-count">{promoters} / {npsCount}</div>
            </div>
            <div class="nps-segment is-passive">
              <div class="nps-segment-pct">{npsCount > 0 ? Math.round((passives / npsCount) * 100) : 0}%</div>
              <div class="nps-segment-label">Passifs (7-8)</div>
              <div class="nps-segment-count">{passives} / {npsCount}</div>
            </div>
            <div class="nps-segment is-detractor">
              <div class="nps-segment-pct">{npsCount > 0 ? Math.round((detractors / npsCount) * 100) : 0}%</div>
              <div class="nps-segment-label">Détracteurs (0-6)</div>
              <div class="nps-segment-count">{detractors} / {npsCount}</div>
            </div>
          </div>
          <div class="dist">
            {npsDist.map(item => {
              const tone = item.value >= 9 ? 'is-promoter' : item.value >= 7 ? 'is-passive' : 'is-detractor';
              return (
                <div class={`dist-row nps-row ${tone}`}>
                  <span class="dist-label">{item.value}/10</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.nps)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, npsCount)})</span></span>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Prix jugés raisonnables</h2>
          {PRICE_KEYS.map(qKey => (
            <div class="dist-group">
              <h3 class="dist-group-title">{PRICE_TITLES[qKey]}</h3>
              <div class="dist">
                {(priceDists[qKey] ?? []).map(item => (
                  <div class={`dist-row ${item.value === PRICE_TARGETS[qKey] ? 'is-target' : ''}`}>
                    <span class="dist-label">
                      {labelFor(qKey, item.value)}
                      {item.value === PRICE_TARGETS[qKey] && <span class="target-tag">cible</span>}
                    </span>
                    <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, priceMaxes[qKey])}%`}></div></div>
                    <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Préférences</h2>

          <div class="dist-group">
            <h3 class="dist-group-title">Type de vélo (multi-choix)</h3>
            <div class="dist">
              {multiBikeType.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('bike_type', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.bikeType)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">Durée préférée</h3>
            <div class="dist">
              {durationDist.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('duration', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.duration)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">Contextes d'utilisation (multi-choix)</h3>
            <div class="dist">
              {multiContexts.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('contexts', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.contexts)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Services prioritaires</h2>

          <div class="dist-group">
            <h3 class="dist-group-title">Notés « Indispensable »</h3>
            <div class="dist">
              {servicesEssential.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{matrixRowLabel(item.key)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.servicesEssential)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">Service le plus déterminant</h3>
            <div class="dist">
              {topService.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('top_service', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.topService)}%`}></div></div>
                  <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Profil des répondants</h2>
          {PROFILE_KEYS.map(qKey => (
            <div class="dist-group">
              <h3 class="dist-group-title">{PROFILE_TITLES[qKey]}</h3>
              <div class="dist">
                {(profileDists[qKey] ?? []).map(item => (
                  <div class="dist-row">
                    <span class="dist-label">{labelFor(qKey, item.value)}</span>
                    <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, profileMaxes[qKey])}%`}></div></div>
                    <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Principal frein</h2>
          <div class="dist">
            {mainConcern.map(item => (
              <div class="dist-row">
                <span class="dist-label">{labelFor('main_concern', item.value)}</span>
                <div class="dist-bar"><div class="dist-fill" style={`width:${widthPct(item.n, maxes.mainConcern)}%`}></div></div>
                <span class="dist-count">{item.n} <span class="dist-pct">({pct(item.n, total)})</span></span>
              </div>
            ))}
          </div>
        </section>
      )}

      {total > 0 && (
        <section class="admin-section">
          <h2 class="admin-subtitle">Analyses croisées</h2>

          <div class="dist-group">
            <h3 class="dist-group-title">Score d'intérêt moyen × pratique du vélo</h3>
            <div class="dist">
              {crossInterestByPractice.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('practice', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${item.avg * 10}%`}></div></div>
                  <span class="dist-count">{item.avg.toFixed(1)}/10 <span class="dist-pct">(n={item.n})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">Score d'intérêt moyen × valeur du vélo actuel</h3>
            <div class="dist">
              {crossInterestByBikeValue.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('bike_value', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${item.avg * 10}%`}></div></div>
                  <span class="dist-count">{item.avg.toFixed(1)}/10 <span class="dist-pct">(n={item.n})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">% à fort intérêt (≥ 7) × région</h3>
            <div class="dist">
              {crossHighInterestByRegion.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('region', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${item.pct}%`}></div></div>
                  <span class="dist-count">{Math.round(item.pct)}% <span class="dist-pct">({item.matches}/{item.n})</span></span>
                </div>
              ))}
            </div>
          </div>

          <div class="dist-group">
            <h3 class="dist-group-title">% acceptant ≥ $500/semaine × pratique du vélo</h3>
            <div class="dist">
              {crossPriceTargetByPractice.map(item => (
                <div class="dist-row">
                  <span class="dist-label">{labelFor('practice', item.value)}</span>
                  <div class="dist-bar"><div class="dist-fill" style={`width:${item.pct}%`}></div></div>
                  <span class="dist-count">{Math.round(item.pct)}% <span class="dist-pct">({item.matches}/{item.n})</span></span>
                </div>
              ))}
            </div>
          </div>
        </section>
      )}

      {total > 0 && (
        <section class="admin-section" id="responses">
          <h2 class="admin-subtitle">Toutes les réponses</h2>
          <p class="admin-meta">{pageStart}–{pageEnd} sur {total}</p>
          <div class="admin-table-wrap">
            <table class="admin-table is-clickable">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Date</th>
                  <th>Lang</th>
                  <th>Pays</th>
                  <th>Âge</th>
                  <th>Région</th>
                  <th>Pratique</th>
                  <th>Intérêt</th>
                  <th>Durée</th>
                  <th>Commentaire</th>
                </tr>
              </thead>
              <tbody>
                {pageResponses.map((r: SurveyResponse) => (
                  <tr onclick={`window.location='${detailUrl(r.id)}'`}>
                    <td>{r.id}</td>
                    <td>{fmtDate(r.created_at)}</td>
                    <td>{r.lang}</td>
                    <td>{r.ip_country ?? '—'}</td>
                    <td>{labelFor('age', r.age)}</td>
                    <td>{labelFor('region', r.region)}</td>
                    <td>{labelFor('practice', r.practice)}</td>
                    <td>{r.interest}/10</td>
                    <td>{labelFor('duration', r.duration)}</td>
                    <td class="td-comment">{previewComment(r.comments)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {totalPages > 1 && (
            <nav class="pagination">
              <a href={pageUrl(1)} class={`pag-btn ${currentPage === 1 ? 'is-disabled' : ''}`} aria-label="Premier">«</a>
              <a href={pageUrl(currentPage - 1)} class={`pag-btn ${currentPage === 1 ? 'is-disabled' : ''}`}>← Précédent</a>
              <span class="pag-info">Page {currentPage} / {totalPages}</span>
              <a href={pageUrl(currentPage + 1)} class={`pag-btn ${currentPage === totalPages ? 'is-disabled' : ''}`}>Suivant →</a>
              <a href={pageUrl(totalPages)} class={`pag-btn ${currentPage === totalPages ? 'is-disabled' : ''}`} aria-label="Dernier">»</a>
            </nav>
          )}
        </section>
      )}

    </div>
  </main>

  <footer>
    <span>© 2026 Lacet</span>
    <span class="footer-center">Admin{isTest && ' · Mode test'}</span>
    <span>lacet.ca</span>
  </footer>

</Base>
