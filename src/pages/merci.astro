---
import Base from '../layouts/Base.astro';
import Footer from '../components/Footer.astro';
import { useTranslations } from '../i18n';
const tr = useTranslations('fr');
---
<Base title={tr.title_thanks} lang="fr">

  <header class="corner">
    <div class="corner-left">
      <span class="dot"></span>
      <span>{tr.region}</span>
    </div>
    <nav class="lang-switcher">
      <span class="lang-active">{tr.lang_self}</span>
      <span class="lang-sep">·</span>
      <a href={tr.alt_thanks}>{tr.lang_other}</a>
    </nav>
  </header>

  <main class="centered">
    <div class="content-page">
      <div class="big-center">
        <h1>{tr.thanks_title}</h1>
        <p>{tr.thanks_body}</p>
        <a href="/" class="home-link">{tr.thanks_back}</a>
      </div>
    </div>
  </main>

  <Footer lang="fr" />

</Base>
