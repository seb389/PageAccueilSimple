---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = useTranslations(lang);
---

<footer>
  <span>{tr.footer_copy}</span>
  <span class="footer-center"><a href={tr.nl_privacy_href}>{tr.footer_privacy}</a></span>
  <span class="footer-right">
    <a class="footer-social" href="https://www.instagram.com/lacet.ca/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="5" />
        <circle cx="12" cy="12" r="4" />
        <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor" stroke="none" />
      </svg>
    </a>
    <a class="footer-social" href="https://www.facebook.com/profile.php?id=61564719693961" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
      </svg>
    </a>
    <span>{tr.footer_domain}</span>
  </span>
</footer>
