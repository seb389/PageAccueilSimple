---
import NewsletterForm from './NewsletterForm.astro';
import type { Lang } from '../i18n';
import { SURVEY_LAUNCH_DATE, daysUntilLaunch } from '../launch';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const days = daysUntilLaunch();

const launchDateLabel = lang === 'fr'
  ? SURVEY_LAUNCH_DATE.toLocaleDateString('fr-CA', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'America/Toronto' })
  : SURVEY_LAUNCH_DATE.toLocaleDateString('en-CA', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'America/Toronto' });

const copy = lang === 'fr' ? {
  bannerOpening:  "Ouverture du sondage",
  bannerSeparator:"—",
  h1:             "Le vélo de route, autrement",
  tagline:        "Avant de bâtir, on écoute.",
  context:        "Un service québécois de location de vélos de route haut de gamme. Livraison, entretien et assurance inclus — pour que la location ressemble enfin à une vraie sortie de cycliste, pas à un dépannage.",
  formPrompt:     "Soyez avisé·e à l'ouverture",
  contestBody:    "Un tirage parmi les répondants.",
} : {
  bannerOpening:  "Survey opens",
  bannerSeparator:"—",
  h1:             "Road cycling, reimagined",
  tagline:        "Before we build, we listen.",
  context:        "A Quebec-based premium road bike rental service. Delivery, maintenance and insurance included — so the rental finally feels like a real cyclist's ride, not a workaround.",
  formPrompt:     "Get notified at launch",
  contestBody:    "A draw among respondents.",
};

const dayPrefix = lang === 'fr' ? 'J' : 'D';
---

<section class="teaser" data-launch-iso={SURVEY_LAUNCH_DATE.toISOString()} data-day-prefix={dayPrefix}>
  <h1 class="teaser-h1">{copy.h1}</h1>
  <p class="teaser-tagline">{copy.tagline}</p>

  <div class="teaser-context">
    <p>{copy.context}</p>
  </div>

  <div class="teaser-banner">
    <span class="teaser-countdown" data-countdown>{dayPrefix}-{days}</span>
    <span class="teaser-banner-text">
      {copy.bannerOpening} <span class="teaser-banner-sep">{copy.bannerSeparator}</span> {launchDateLabel}
    </span>
  </div>

  <div class="teaser-form-wrap">
    <NewsletterForm
      lang={lang}
      source="teaser"
      prompt={copy.formPrompt}
    >
      <svg slot="icon" class="thanks-block-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
      </svg>
    </NewsletterForm>
  </div>

  <p class="teaser-contest">
    <svg class="thanks-block-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="20 12 20 22 4 22 4 12" />
      <rect x="2" y="7" width="20" height="5" />
      <line x1="12" y1="22" x2="12" y2="7" />
      <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
      <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
    </svg>
    {copy.contestBody}
  </p>
</section>

<script is:inline>
  // Recompute J-N on page load — handles back-cache or pages held open across midnight.
  (function () {
    const el = document.querySelector('[data-countdown]');
    if (!el) return;
    const root = el.closest('[data-launch-iso]');
    if (!root) return;
    const launch = new Date(root.dataset.launchIso);
    if (Number.isNaN(launch.getTime())) return;
    const prefix = root.dataset.dayPrefix || 'J';
    const ms = launch.getTime() - Date.now();
    const days = Math.max(0, Math.ceil(ms / 86400000));
    el.textContent = prefix + '-' + days;
  })();
</script>
