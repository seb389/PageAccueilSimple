---
import NewsletterForm from './NewsletterForm.astro';
import type { Lang } from '../i18n';
import { SURVEY_LAUNCH_DATE, daysUntilLaunch } from '../launch';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const days = daysUntilLaunch();

const launchDateLabel = lang === 'fr'
  ? SURVEY_LAUNCH_DATE.toLocaleDateString('fr-CA', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'America/Toronto' })
  : SURVEY_LAUNCH_DATE.toLocaleDateString('en-CA', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'America/Toronto' });

const copy = lang === 'fr' ? {
  bannerOpening:  "Ouverture du sondage",
  bannerSeparator:"—",
  h1:             "Repensons la location de vélo de route au Québec",
  tagline:        `Avant de bâtir, on écoute. Notre sondage ouvre le ${launchDateLabel}.`,
  context: [
    "Louer un vélo de route qui vibre vraiment au Québec, ce n'est pas évident aujourd'hui. Que ce soit pour un voyage, une course, un week-end de découverte ou simplement le plaisir d'essayer un modèle de rêve avant de l'acheter, l'offre actuelle laisse beaucoup de place à autre chose.",
    "Nous explorons un service où la livraison à domicile, l'entretien, l'assurance et le bike fit sont inclus dans la location — pour que l'expérience ressemble enfin à une vraie sortie de cycliste, pas à un dépannage. Avant de mettre le tout en place, nous voulons d'abord vous entendre.",
  ],
  formPrompt:     "Soyez avisé·e dès l'ouverture du sondage",
  formDescription:`Le ${launchDateLabel}, nous lancerons un court sondage de 3 à 5 minutes. Laissez-nous votre courriel pour recevoir le lien dès la première heure et participer aux décisions qui façonneront Lacet.`,
  formFootnote:   "Nous n'utiliserons votre courriel que pour vous aviser de l'ouverture du sondage et, si vous le souhaitez, vous tenir au courant du projet. Désinscription en un clic, en tout temps.",
  contestTitle:   "Un tirage à la fin du sondage",
  contestBody:    `Tous les répondants pourront participer à un tirage exclusif lié à un produit ou service vélo haut de gamme. Les détails seront publiés à l'ouverture du sondage le ${launchDateLabel}.`,
} : {
  bannerOpening:  "Survey opens",
  bannerSeparator:"—",
  h1:             "Rethinking road bike rental in Quebec",
  tagline:        `Before we build, we listen. Our survey opens on ${launchDateLabel}.`,
  context: [
    "Renting a road bike that truly lives up to Quebec's roads isn't easy today. Whether for travel, a race, a discovery weekend, or simply the pleasure of trying a dream bike before buying, today's options leave plenty of room for something better.",
    "We're exploring a service where home delivery, maintenance, insurance and bike fit are all included in the rental — so the experience finally feels like a real cyclist's ride, not a workaround. Before we put it together, we want to hear from you first.",
  ],
  formPrompt:     "Get notified when the survey opens",
  formDescription:`On ${launchDateLabel}, we'll launch a short 3-to-5-minute survey. Leave us your email to receive the link as soon as it goes live and help shape Lacet's decisions.`,
  formFootnote:   "We will only use your email to notify you of the survey opening and, if you wish, to keep you updated on the project. One-click unsubscribe, anytime.",
  contestTitle:   "A draw at the end of the survey",
  contestBody:    `All respondents will be eligible for an exclusive draw linked to a premium cycling product or service. Details will be published when the survey opens on ${launchDateLabel}.`,
};

const dayPrefix = lang === 'fr' ? 'J' : 'D';
---

<section class="teaser" data-launch-iso={SURVEY_LAUNCH_DATE.toISOString()} data-day-prefix={dayPrefix}>
  <div class="teaser-banner">
    <span class="teaser-countdown" data-countdown>{dayPrefix}-{days}</span>
    <span class="teaser-banner-text">
      {copy.bannerOpening} <span class="teaser-banner-sep">{copy.bannerSeparator}</span> {launchDateLabel}
    </span>
  </div>

  <h1 class="teaser-h1">{copy.h1}</h1>
  <p class="teaser-tagline">{copy.tagline}</p>

  <div class="teaser-context">
    {copy.context.map(p => <p>{p}</p>)}
  </div>

  <div class="teaser-form-wrap">
    <NewsletterForm
      lang={lang}
      source="teaser"
      prompt={copy.formPrompt}
      description={copy.formDescription}
    />
    <p class="teaser-form-footnote">{copy.formFootnote}</p>
  </div>

  <div class="teaser-block teaser-contest">
    <h2>{copy.contestTitle}</h2>
    <p>{copy.contestBody}</p>
  </div>
</section>

<script is:inline>
  // Recompute J-N on page load — handles back-cache or pages held open across midnight.
  (function () {
    const el = document.querySelector('[data-countdown]');
    if (!el) return;
    const root = el.closest('[data-launch-iso]');
    if (!root) return;
    const launch = new Date(root.dataset.launchIso);
    if (Number.isNaN(launch.getTime())) return;
    const prefix = root.dataset.dayPrefix || 'J';
    const ms = launch.getTime() - Date.now();
    const days = Math.max(0, Math.ceil(ms / 86400000));
    el.textContent = prefix + '-' + days;
  })();
</script>
