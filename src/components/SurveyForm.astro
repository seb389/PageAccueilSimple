---
import type { Lang } from '../i18n';
import { survey, type Question } from '../survey';
import { env } from 'cloudflare:workers';

interface Props { lang: Lang }
const { lang } = Astro.props;
const content = survey[lang];
const turnstileSiteKey = env?.TURNSTILE_SITE_KEY ?? '';

let globalIndex = 0;
const numberedSections = content.sections.map(section => ({
  ...section,
  questions: section.questions.map(q => ({ ...q, number: ++globalIndex })),
}));

const totalSteps = numberedSections.length;
const nextLabel   = lang === 'fr' ? 'Suivant' : 'Next';
const prevLabel   = lang === 'fr' ? 'Précédent' : 'Previous';
const stepOfLabel = lang === 'fr' ? 'Étape' : 'Step';
const ofLabel     = lang === 'fr' ? 'de' : 'of';
---

<section class="survey" data-lang={lang}>

  <header class="survey-intro">
    <h1 class="survey-title">{content.intro.heading}</h1>
    {content.intro.paragraphs.map(p => <p>{p}</p>)}
    <p class="survey-signature">{content.intro.signature}</p>
    <p class="survey-time">
      <span class="dot"></span>
      <span>{content.intro.timeEstimate}</span>
    </p>
  </header>

  <form class="survey-form" novalidate>

    <div class="survey-progress">
      <span class="survey-progress-counter"></span>
      <div class="survey-progress-track">
        <div class="survey-progress-fill"></div>
      </div>
    </div>

    {numberedSections.map((section, i) => (
      <fieldset class="survey-section" data-step={i + 1} data-section={section.id} hidden={i !== 0}>
        <legend>
          <span class="survey-section-title">{section.title}</span>
          {section.intro && <span class="survey-section-intro" set:html={section.intro} />}
        </legend>

        {section.questions.map((q: Question & { number: number }) => (
          <div
            class="q"
            data-qkey={q.key}
            data-qtype={q.type}
            data-showif-key={q.showIf?.key}
            data-showif-equals={q.showIf?.equals}
            data-showif-not-equals={q.showIf?.notEquals}
            hidden={q.showIf != null}
          >
            <div class="q-label">
              <span class="q-num">Q{q.number}.</span>
              <span>
                {q.label}
                {q.required && <span class="q-required" aria-label="obligatoire">*</span>}
              </span>
            </div>
            {'hint' in q && q.hint && <p class="q-hint">{q.hint}</p>}

            {q.type === 'radio' && (
              <div class="q-options">
                {q.options.map(opt => (
                  <label class="opt">
                    <input type="radio" name={q.key} value={opt.value} required={q.required} />
                    <span class="opt-custom"></span>
                    <span class="opt-label">{opt.label}</span>
                  </label>
                ))}
              </div>
            )}

            {q.type === 'checkbox' && (
              <div class="q-options" data-required={q.required ? 'true' : 'false'}>
                {q.options.map(opt => (
                  <label class="opt">
                    <input type="checkbox" name={q.key} value={opt.value} />
                    <span class="opt-custom opt-check"></span>
                    <span class="opt-label">{opt.label}</span>
                  </label>
                ))}
              </div>
            )}

            {q.type === 'scale' && (
              <div class="q-scale">
                <div class="scale-track">
                  {Array.from({ length: q.max - q.min + 1 }, (_, i) => q.min + i).map(n => (
                    <label class="scale-cell">
                      <input type="radio" name={q.key} value={n} required={q.required} />
                      <span class="scale-dot">{n}</span>
                    </label>
                  ))}
                </div>
                <div class="scale-labels">
                  <span>{q.minLabel}</span>
                  <span>{q.maxLabel}</span>
                </div>
              </div>
            )}

            {q.type === 'textarea' && (
              <textarea
                name={q.key}
                rows="5"
                placeholder={q.placeholder ?? ''}
                required={q.required}
              ></textarea>
            )}

            {q.type === 'matrix' && (
              <div class="q-matrix" data-keys={q.rows.map(r => r.key).join(',')}>
                <div class="matrix-grid" style={`--cols:${q.columns.length}`}>
                  <div class="matrix-header"></div>
                  {q.columns.map(col => (
                    <div class="matrix-col-label">{col.label}</div>
                  ))}
                  {q.rows.map(row => (
                    <div class="matrix-row">
                      <div class="matrix-row-label">{row.label}</div>
                      <div class="matrix-row-track">
                        {q.columns.map((col, i) => (
                          <label class="matrix-cell">
                            <input type="radio" name={row.key} value={col.value} required={q.required} />
                            <span class="matrix-dot" aria-label={col.label}></span>
                            <span class="matrix-cell-num" aria-hidden="true">{q.columns.length - i}</span>
                          </label>
                        ))}
                      </div>
                      <div class="matrix-row-extremes" aria-hidden="true">
                        <span>{q.columns[q.columns.length - 1].label}</span>
                        <span>{q.columns[0].label}</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        {i === numberedSections.length - 1 && (
          <>
            <section class="survey-newsletter survey-contest">
              <div class="survey-newsletter-head">
                <span class="survey-newsletter-title">{content.contestOptIn.title}</span>
                <p class="survey-newsletter-hint">{content.contestOptIn.hint}</p>
              </div>
              <label class="opt survey-nl-toggle">
                <input type="checkbox" name="contest_optin" />
                <span class="opt-custom opt-check"></span>
                <span class="opt-label">{content.contestOptIn.enableLabel}</span>
              </label>
              <div class="survey-contest-fields" hidden>
                <div class="contest-row">
                  <input type="text" name="contest_name" autocomplete="name"
                    placeholder={content.contestOptIn.namePlaceholder}
                    aria-label={content.contestOptIn.namePlaceholder} />
                </div>
                <div class="contest-row">
                  <input type="email" name="contest_email" inputmode="email" autocomplete="email"
                    placeholder={content.contestOptIn.emailPlaceholder}
                    aria-label={content.contestOptIn.emailPlaceholder} />
                </div>
                <label class="nl-consent survey-nl-consent">
                  <input type="checkbox" name="contest_rules" />
                  <span>
                    {content.contestOptIn.rulesBefore}{' '}
                    <a href={content.contestOptIn.rulesHref}>{content.contestOptIn.rulesLink}</a>{content.contestOptIn.rulesAfter}
                  </span>
                </label>
              </div>
            </section>

            <section class="survey-newsletter">
              <div class="survey-newsletter-head">
                <span class="survey-newsletter-title">{content.newsletterOptIn.title}</span>
                <p class="survey-newsletter-hint">{content.newsletterOptIn.hint}</p>
              </div>
              <label class="opt survey-nl-toggle">
                <input type="checkbox" name="newsletter_optin" />
                <span class="opt-custom opt-check"></span>
                <span class="opt-label">{content.newsletterOptIn.enableLabel}</span>
              </label>
              <div class="survey-nl-fields" hidden>
                <div class="nl-input-group">
                  <input type="email" name="newsletter_email" inputmode="email" autocomplete="email"
                    placeholder={content.newsletterOptIn.emailPlaceholder}
                    aria-label={content.newsletterOptIn.emailPlaceholder} />
                </div>
                <label class="nl-consent survey-nl-consent">
                  <input type="checkbox" name="newsletter_consent" />
                  <span>
                    {content.newsletterOptIn.consentBefore}{' '}
                    <a href={content.newsletterOptIn.privacyHref}>{content.newsletterOptIn.consentLink}</a>{content.newsletterOptIn.consentAfter}
                  </span>
                </label>
              </div>
            </section>

            <div class="survey-captcha">
              <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-size="flexible"></div>
            </div>
          </>
        )}
      </fieldset>
    ))}

    <p class="survey-error" role="alert" hidden></p>

    <p class="survey-required-note">{content.requiredNote}</p>

    <div class="survey-nav">
      <button type="button" class="survey-btn-prev" hidden>{prevLabel}</button>
      <button type="button" class="survey-btn-next">{nextLabel}</button>
      <button type="submit" class="survey-submit" hidden>
        <span class="submit-label">{content.submit}</span>
      </button>
    </div>

  </form>

</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script is:inline define:vars={{
  messages: {
    required:               content.errors.required,
    network:                content.errors.network,
    default:                content.errors.default,
    invalid_email:          content.errors.invalid_email,
    consent_required:       content.errors.consent_required,
    contest_name_required:  lang === 'fr' ? "Veuillez entrer votre nom pour participer au concours." : "Please enter your name to enter the contest.",
    contest_rules_required: lang === 'fr' ? "Veuillez accepter le règlement du concours." : "Please accept the contest rules.",
    captcha_missing:        lang === 'fr' ? "Veuillez patienter — la vérification anti-bot se charge." : "Please wait — the anti-bot check is loading.",
    captcha_failed:         lang === 'fr' ? "Vérification anti-bot échouée. Rechargez la page et réessayez." : "Anti-bot verification failed. Please reload the page and try again.",
  },
  submitLabel:     content.submit,
  submittingLabel: content.submitting,
  TOTAL_STEPS:     totalSteps,
  stepOfLabel:     stepOfLabel,
  ofLabel:         ofLabel,
}}>
(function () {
  const form = document.querySelector('.survey-form');
  if (!form) return;

  const errorEl       = form.querySelector('.survey-error');
  const btnSubmit     = form.querySelector('.survey-submit');
  const btnLabel      = btnSubmit.querySelector('.submit-label');
  const btnNext       = form.querySelector('.survey-btn-next');
  const btnPrev       = form.querySelector('.survey-btn-prev');
  const progressFill  = form.querySelector('.survey-progress-fill');
  const progressCounter = form.querySelector('.survey-progress-counter');
  const lang = document.querySelector('.survey').dataset.lang || 'fr';

  if (window.lacetTrack) {
    window.lacetTrack('ViewContent', { content_category: 'survey' });
  }

  // ── Step management ──────────────────────────────────────────────────
  var currentStep = 1;

  function showStep(n) {
    form.querySelectorAll('[data-step]').forEach(function(el) { el.hidden = true; });
    var stepEl = form.querySelector('[data-step="' + n + '"]');
    if (stepEl) stepEl.hidden = false;

    var pct = ((n - 1) / (TOTAL_STEPS - 1)) * 100;
    progressFill.style.width = pct + '%';
    progressCounter.textContent = stepOfLabel + ' ' + n + ' ' + ofLabel + ' ' + TOTAL_STEPS;

    btnPrev.hidden   = n === 1;
    btnNext.hidden   = n === TOTAL_STEPS;
    btnSubmit.hidden = n !== TOTAL_STEPS;

    applyShowIf();
    clearError();
    document.querySelector('.survey').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ── Conditional questions (showIf) ───────────────────────────────────
  var conditionals = Array.from(form.querySelectorAll('.q[data-showif-key]'));

  function getCurrentValue(parentKey) {
    var checked = form.querySelector('input[type="radio"][name="' + CSS.escape(parentKey) + '"]:checked');
    return checked ? checked.value : null;
  }

  function isVisible(qEl) {
    var parentKey = qEl.dataset.showifKey;
    var equals    = qEl.dataset.showifEquals;
    var notEquals = qEl.dataset.showifNotEquals;
    var v = getCurrentValue(parentKey);
    if (equals    !== undefined && equals    !== '') return v === equals;
    if (notEquals !== undefined && notEquals !== '') return v != null && v !== notEquals;
    return true;
  }

  function clearAnswers(qEl) {
    qEl.querySelectorAll('input').forEach(function(inp) {
      if (inp.type === 'radio' || inp.type === 'checkbox') inp.checked = false;
      else inp.value = '';
    });
    qEl.querySelectorAll('textarea').forEach(function(t) { t.value = ''; });
  }

  function applyShowIf() {
    conditionals.forEach(function(qEl) {
      var visible = isVisible(qEl);
      if (qEl.hidden && visible)       { qEl.hidden = false; }
      else if (!qEl.hidden && !visible) { clearAnswers(qEl); qEl.hidden = true; }
    });
  }

  if (conditionals.length) {
    form.addEventListener('change', applyShowIf);
  }

  // ── Newsletter & Contest toggles ─────────────────────────────────────
  var nlToggle = form.querySelector('input[name="newsletter_optin"]');
  var nlFields = form.querySelector('.survey-nl-fields');
  var nlEmail  = form.querySelector('input[name="newsletter_email"]');
  var nlConsent= form.querySelector('input[name="newsletter_consent"]');

  var ctToggle = form.querySelector('input[name="contest_optin"]');
  var ctFields = form.querySelector('.survey-contest-fields');
  var ctName   = form.querySelector('input[name="contest_name"]');
  var ctEmail  = form.querySelector('input[name="contest_email"]');
  var ctRules  = form.querySelector('input[name="contest_rules"]');

  nlToggle.addEventListener('change', function() {
    nlFields.hidden = !nlToggle.checked;
    if (!nlToggle.checked) { nlEmail.value = ''; nlConsent.checked = false; }
    else setTimeout(function() { nlEmail.focus(); }, 50);
  });

  ctToggle.addEventListener('change', function() {
    ctFields.hidden = !ctToggle.checked;
    if (!ctToggle.checked) { ctName.value = ''; ctEmail.value = ''; ctRules.checked = false; }
    else setTimeout(function() { ctName.focus(); }, 50);
  });

  // ── Error display ────────────────────────────────────────────────────
  function showError(msg, scrollTarget) {
    errorEl.textContent = msg;
    errorEl.hidden = false;
    (scrollTarget || errorEl).scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
  function clearError() { errorEl.hidden = true; errorEl.textContent = ''; }

  // ── Per-step validation ──────────────────────────────────────────────
  function validateCurrentStep() {
    var stepEl = form.querySelector('[data-step="' + currentStep + '"]');
    var qs = Array.from(stepEl.querySelectorAll('.q:not([hidden])'));

    for (var i = 0; i < qs.length; i++) {
      var qEl     = qs[i];
      var type    = qEl.dataset.qtype;
      var required = qEl.querySelector('.q-required') !== null;
      if (!required) continue;

      if (type === 'radio' || type === 'scale') {
        if (!qEl.querySelector('input[type="radio"]:checked')) {
          showError(messages.required, qEl);
          return false;
        }
      } else if (type === 'checkbox') {
        var opts = qEl.querySelector('.q-options');
        if (opts && opts.dataset.required === 'true') {
          if (qEl.querySelectorAll('input[type="checkbox"]:checked').length === 0) {
            showError(messages.required, qEl);
            return false;
          }
        }
      } else if (type === 'matrix') {
        var matrixKeys = qEl.querySelector('.q-matrix').dataset.keys.split(',');
        for (var k = 0; k < matrixKeys.length; k++) {
          if (!qEl.querySelector('input[name="' + CSS.escape(matrixKeys[k]) + '"]:checked')) {
            showError(messages.required, qEl);
            return false;
          }
        }
      }
    }
    return true;
  }

  // ── Navigation ───────────────────────────────────────────────────────
  btnNext.addEventListener('click', function() {
    clearError();
    if (!validateCurrentStep()) return;
    currentStep++;
    showStep(currentStep);
  });

  btnPrev.addEventListener('click', function() {
    clearError();
    currentStep--;
    showStep(currentStep);
  });

  // ── Data collection ──────────────────────────────────────────────────
  function collect() {
    var data = { lang: lang };
    var formData = new FormData(form);

    form.querySelectorAll('.q').forEach(function(qEl) {
      if (qEl.hidden) return;
      var key      = qEl.dataset.qkey;
      var type     = qEl.dataset.qtype;
      var required = qEl.querySelector('.q-required') !== null;

      if (type === 'radio' || type === 'scale') {
        var v = formData.get(key);
        if (v != null) data[key] = type === 'scale' ? Number(v) : v;
        else if (required) throw new Error('missing:' + key);
      } else if (type === 'checkbox') {
        var vals = formData.getAll(key);
        if (required && vals.length === 0) throw new Error('missing:' + key);
        data[key] = vals;
      } else if (type === 'textarea') {
        var tv = formData.get(key);
        data[key] = (tv || '').trim();
      } else if (type === 'matrix') {
        var keys = qEl.querySelector('.q-matrix').dataset.keys.split(',');
        for (var k = 0; k < keys.length; k++) {
          var mv = formData.get(keys[k]);
          if (mv != null) data[keys[k]] = mv;
          else if (required) throw new Error('missing:' + keys[k]);
        }
      }
    });

    if (nlToggle.checked) {
      var nlMail = (nlEmail.value || '').trim().toLowerCase();
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(nlMail)) throw new Error('invalid_email');
      if (!nlConsent.checked) throw new Error('consent_required');
      data.newsletter_optin   = true;
      data.newsletter_email   = nlMail;
      data.newsletter_consent = true;
    }

    if (ctToggle.checked) {
      var name   = (ctName.value  || '').trim();
      var ctMail = (ctEmail.value || '').trim().toLowerCase();
      if (!name) throw new Error('contest_name_required');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(ctMail)) throw new Error('contest_email_invalid');
      if (!ctRules.checked) throw new Error('contest_rules_required');
      data.contest_optin = true;
      data.contest_name  = name;
      data.contest_email = ctMail;
      data.contest_rules = true;
    }

    var captchaToken = formData.get('cf-turnstile-response');
    if (!captchaToken) throw new Error('captcha_missing');
    data.captcha_token = String(captchaToken);

    var consentRaw = '';
    try { consentRaw = localStorage.getItem('lacet_consent_v1') || ''; } catch (e) {}
    data.tracking_consent = consentRaw.indexOf('accepted:') === 0 ? 'accepted' : 'declined';

    data.event_id = (window.crypto && window.crypto.randomUUID)
      ? window.crypto.randomUUID()
      : String(Date.now()) + '-' + Math.random().toString(36).slice(2);

    return data;
  }

  // ── Submit ───────────────────────────────────────────────────────────
  form.addEventListener('submit', async function(e) {
    e.preventDefault();
    clearError();

    var payload;
    try {
      payload = collect();
    } catch (err) {
      var msg = String(err.message || '');
      if (msg.startsWith('missing:')) {
        var missingKey = msg.replace(/^missing:/, '');
        var target = form.querySelector('[name="' + missingKey + '"]');
        showError(messages.required, target ? target.closest('.q') : null);
      } else if (msg === 'invalid_email') {
        showError(messages.invalid_email, nlEmail.closest('.survey-newsletter'));
      } else if (msg === 'consent_required') {
        showError(messages.consent_required, nlConsent.closest('.survey-newsletter'));
      } else if (msg === 'contest_name_required') {
        showError(messages.contest_name_required, ctName.closest('.survey-contest'));
        ctName.focus();
      } else if (msg === 'contest_email_invalid') {
        showError(messages.invalid_email, ctEmail.closest('.survey-contest'));
        ctEmail.focus();
      } else if (msg === 'contest_rules_required') {
        showError(messages.contest_rules_required, ctRules.closest('.survey-contest'));
      } else if (msg === 'captcha_missing') {
        showError(messages.captcha_missing, form.querySelector('.survey-captcha'));
      } else {
        showError(messages.default);
      }
      return;
    }

    btnSubmit.disabled = true;
    btnLabel.textContent = submittingLabel;

    try {
      var res = await fetch('/api/survey', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(payload),
      });
      var data = await res.json().catch(function() { return { ok: false }; });
      if (data.ok) {
        if (payload.contest_optin && window.lacetTrack) {
          window.lacetTrack('Lead', { content_category: 'survey' }, payload.event_id);
        }
        var base = lang === 'fr' ? '/merci-sondage' : '/en/thanks-survey';
        var params = [];
        if (payload.contest_optin)    params.push('concours=1');
        if (payload.newsletter_optin) params.push('infolettre=1');
        window.location.href = params.length ? base + '?' + params.join('&') : base;
      } else if (data.error === 'captcha_failed') {
        showError(messages.captcha_failed, form.querySelector('.survey-captcha'));
        if (window.turnstile) window.turnstile.reset();
        btnSubmit.disabled = false;
        btnLabel.textContent = submitLabel;
      } else {
        showError(messages.default);
        btnSubmit.disabled = false;
        btnLabel.textContent = submitLabel;
      }
    } catch {
      showError(messages.network);
      btnSubmit.disabled = false;
      btnLabel.textContent = submitLabel;
    }
  });

  // ── Init ─────────────────────────────────────────────────────────────
  showStep(1);
})();
</script>

<style is:global>
  .survey-progress {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .survey-progress-counter {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fumee);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .survey-progress-track {
    flex: 1;
    height: 2px;
    background: color-mix(in srgb, var(--fumee) 25%, transparent);
    border-radius: 1px;
    overflow: hidden;
  }
  .survey-progress-fill {
    height: 100%;
    background: var(--cuivre);
    border-radius: 1px;
    transition: width 0.35s ease;
    width: 0%;
  }

  .survey-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 48px;
    gap: 1rem;
  }
  .survey-btn-prev {
    background: transparent;
    border: 1px solid var(--fumee);
    color: var(--fumee);
    padding: 14px 28px;
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
    flex-shrink: 0;
  }
  .survey-btn-prev:hover {
    border-color: var(--craie);
    color: var(--craie);
  }
  .survey-btn-next {
    margin-left: auto;
    background: var(--craie);
    color: var(--charbon);
    border: none;
    padding: 16px 40px;
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .survey-btn-next:hover {
    background: var(--cuivre);
    color: var(--craie);
  }
</style>
