---
import { useTranslations, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const tr = useTranslations(lang);

const shareUrlEnc      = encodeURIComponent(tr.thanks_share_url);
const shareSmsBodyEnc  = encodeURIComponent(tr.thanks_share_sms_body);
const shareMailSubjEnc = encodeURIComponent(tr.thanks_share_mail_subject);
const shareMailBodyEnc = encodeURIComponent(tr.thanks_share_mail_body);

const fbShareHref   = `https://www.facebook.com/sharer/sharer.php?u=${shareUrlEnc}`;
const smsShareHref  = `sms:?body=${shareSmsBodyEnc}`;
const mailShareHref = `mailto:?subject=${shareMailSubjEnc}&body=${shareMailBodyEnc}`;
---

<div class="thanks-page">
  <section class="thanks-hero">
    <h1>{tr.thanks_survey_title}</h1>
    <p>{tr.thanks_survey_body}</p>
    <p class="thanks-signoff">{tr.thanks_survey_signoff}</p>
  </section>

  <section class="thanks-block thanks-contest" data-block="contest" hidden>
    <h2>
      <svg class="thanks-block-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="20 12 20 22 4 22 4 12" />
        <rect x="2" y="7" width="20" height="5" />
        <line x1="12" y1="22" x2="12" y2="7" />
        <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
        <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
      </svg>
      {tr.thanks_contest_title}
    </h2>
    <p>
      {tr.thanks_contest_body} <strong>{tr.thanks_contest_prize}</strong> {tr.thanks_contest_value}
    </p>
    <p>
      <strong>{tr.thanks_contest_draw_label}</strong> {tr.thanks_contest_draw_body}
    </p>
    <p class="thanks-contest-luck"><em>{tr.thanks_contest_luck}</em></p>
    <p>
      <a href={tr.thanks_contest_rules_href}>{tr.thanks_contest_rules}</a>
    </p>
  </section>

  <section class="thanks-block thanks-newsletter" data-block="newsletter" hidden>
    <h2>
      <svg class="thanks-block-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
      </svg>
      {tr.thanks_nl_title}
    </h2>
    <p>{tr.thanks_nl_body}</p>
  </section>

  <section class="thanks-block thanks-share">
    <h2>
      <svg class="thanks-block-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18.5" cy="17.5" r="3.5" />
        <circle cx="5.5" cy="17.5" r="3.5" />
        <circle cx="15" cy="5" r="1" />
        <path d="M12 17.5V14l-3-3 4-3 2 3h2" />
      </svg>
      {tr.thanks_share_title}
    </h2>
    <p>{tr.thanks_share_body}</p>
    <div class="thanks-share-primary">
      <a class="thanks-share-fb" href={fbShareHref} target="_blank" rel="noopener noreferrer" data-share="facebook">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z" />
        </svg>
        <span>{tr.thanks_share_facebook}</span>
      </a>
    </div>
    <div class="thanks-share-secondary">
      <a class="thanks-share-link" href={smsShareHref} data-share="sms">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
        </svg>
        <span>{tr.thanks_share_sms}</span>
      </a>
      <a class="thanks-share-link" href={mailShareHref} data-share="email">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2" />
          <polyline points="3 7 12 13 21 7" />
        </svg>
        <span>{tr.thanks_share_email}</span>
      </a>
    </div>
  </section>

</div>

<script is:inline>
  (function () {
    var qs = new URLSearchParams(window.location.search);
    if (qs.get('concours') === '1' || qs.get('contest') === '1') {
      var c = document.querySelector('[data-block="contest"]');
      if (c) c.hidden = false;
    }
    if (qs.get('infolettre') === '1' || qs.get('newsletter') === '1') {
      var n = document.querySelector('[data-block="newsletter"]');
      if (n) n.hidden = false;
    }

    var btns = document.querySelectorAll('[data-share]');
    btns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        if (window.lacetTrack) {
          window.lacetTrack('Share', { method: btn.getAttribute('data-share'), content_category: 'survey' });
        }
      });
    });
  })();
</script>
