---
interface Props {
  title: string;
  lang: 'fr' | 'en';
}
const { title, lang } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="theme-color" content="#0f0f0f" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }

  :root {
    --charbon: #0f0f0f;
    --craie:   #f4f1ec;
    --cuivre:  #b66a3e;
    --fumee:   #8a8680;
    --line:    rgba(244, 241, 236, 0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--charbon);
    color: var(--craie);
    font-family: "Inter", "Helvetica Neue", -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 32px;
    animation: pageIn 1.2s ease-out both;
  }

  @keyframes pageIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes wordmarkIn {
    from { opacity: 0; letter-spacing: 0.5em; }
    to   { opacity: 1; letter-spacing: 0.22em; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Header ── */
  .corner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .corner-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
  }
  .corner-left .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cuivre);
  }
  .corner-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  /* ── Lang switcher ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .lang-switcher a {
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .lang-switcher a:hover { color: var(--craie); }
  .lang-active { color: var(--craie); }
  .lang-sep { color: var(--fumee); opacity: 0.35; }

  .back {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .back:hover { color: var(--craie); }

  /* ── Main ── */
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 16px;
  }
  main.centered {
    justify-content: center;
    text-align: center;
  }

  /* ── Page d'accueil ── */
  .wordmark {
    font-weight: 700;
    letter-spacing: 0.22em;
    font-size: clamp(56px, 14vw, 148px);
    line-height: 1;
    color: var(--craie);
    animation: wordmarkIn 1.4s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .surligne {
    margin-top: 22px;
    font-size: clamp(10px, 1.2vw, 12px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.8s ease-out both;
  }
  .rule {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--cuivre);
    margin: 0 14px;
    vertical-align: middle;
  }
  .status {
    margin-top: 72px;
    font-size: clamp(11px, 1.2vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 1.1s ease-out both;
  }
  .status::before,
  .status::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }
  .contact {
    margin-top: 40px;
    font-size: clamp(12px, 1.4vw, 14px);
    color: var(--fumee);
    letter-spacing: 0.04em;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .contact .label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .contact a {
    color: var(--craie);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    letter-spacing: 0.04em;
    transition: color 0.25s ease, border-color 0.25s ease;
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 400;
  }
  .contact a:hover,
  .contact a:focus {
    color: var(--cuivre);
    border-color: var(--cuivre);
    outline: none;
  }

  /* ── Page sondage ── */
  .page-title {
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .page-title::before,
  .page-title::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }
  .page-sub {
    margin-top: 10px;
    font-size: clamp(10px, 1.2vw, 11px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.5s ease-out both;
  }
  .form-wrapper {
    margin-top: 24px;
    flex: 1;
    width: 100%;
    max-width: 860px;
    border: 1px solid var(--line);
    animation: fadeUp 1.2s 0.7s ease-out both;
    display: flex;
    flex-direction: column;
  }
  .form-wrapper iframe {
    display: block;
    width: 100%;
    flex: 1;
    min-height: calc(100vh - 220px);
    border: none;
    background: var(--charbon);
  }
  .form-link {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    animation: fadeUp 1.2s 0.9s ease-out both;
  }
  .form-link a {
    color: var(--fumee);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .form-link a:hover {
    color: var(--cuivre);
    border-color: var(--cuivre);
  }

  /* ── Newsletter ── */
  .newsletter {
    margin-top: 56px;
    width: 100%;
    max-width: 420px;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .nl-heading {
    text-align: center;
    margin-bottom: 20px;
  }
  .nl-label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 6px;
  }
  .nl-prompt {
    display: block;
    font-size: 13px;
    color: var(--craie);
    letter-spacing: 0.02em;
  }
  .nl-input-group {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--line);
    transition: border-color 0.25s ease;
  }
  .nl-input-group:focus-within {
    border-bottom-color: var(--craie);
  }
  .nl-input-group input[type=email] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--craie);
    font-family: inherit;
    font-size: 14px;
    padding: 12px 0;
    letter-spacing: 0.02em;
    min-width: 0;
  }
  .nl-input-group input[type=email]::placeholder {
    color: var(--fumee);
    opacity: 0.55;
  }
  .nl-input-group button {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    color: var(--craie);
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 12px 0 12px 14px;
    transition: color 0.25s ease;
  }
  .nl-input-group button:hover:not(:disabled),
  .nl-input-group button:focus-visible:not(:disabled) {
    color: var(--cuivre);
    outline: none;
  }
  .nl-input-group button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .nl-arrow {
    font-size: 14px;
    transition: transform 0.25s ease;
  }
  .nl-input-group button:hover:not(:disabled) .nl-arrow {
    transform: translateX(3px);
  }
  .nl-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 16px;
    font-size: 11px;
    line-height: 1.55;
    color: var(--fumee);
    text-align: left;
    cursor: pointer;
    letter-spacing: 0.01em;
  }
  .nl-consent input[type=checkbox] {
    margin-top: 3px;
    accent-color: var(--cuivre);
    flex-shrink: 0;
    cursor: pointer;
  }
  .nl-consent a {
    color: var(--fumee);
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 2px;
    transition: color 0.25s ease, text-decoration-color 0.25s ease;
  }
  .nl-consent a:hover,
  .nl-consent a:focus-visible {
    color: var(--craie);
    text-decoration-color: var(--craie);
  }
  .nl-error {
    margin-top: 14px;
    font-size: 11px;
    line-height: 1.5;
    color: var(--cuivre);
    text-align: center;
    letter-spacing: 0.02em;
  }
  .nl-success {
    text-align: center;
    padding: 24px 0 8px;
  }
  .nl-success-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    margin-bottom: 10px;
  }
  .nl-success-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--fumee);
    max-width: 340px;
    margin: 0 auto;
  }

  /* ── Page contenu (merci, confidentialité) ── */
  .content-page {
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
    padding: 20px 0;
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .content-page h1 {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--craie);
    margin-bottom: 8px;
  }
  .content-page .subtitle {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 40px;
  }
  .content-page h2 {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--craie);
    margin: 32px 0 12px;
  }
  .content-page p,
  .content-page li {
    font-size: 14px;
    line-height: 1.7;
    color: var(--craie);
    margin-bottom: 12px;
  }
  .content-page ul {
    padding-left: 22px;
    margin-bottom: 16px;
  }
  .content-page a {
    color: var(--cuivre);
    text-decoration: underline;
    text-decoration-color: rgba(182, 106, 62, 0.4);
    text-underline-offset: 2px;
  }
  .content-page a:hover {
    text-decoration-color: var(--cuivre);
  }
  .content-page .big-center {
    text-align: center;
    padding: 80px 0 40px;
  }
  .content-page .big-center h1 {
    font-size: clamp(36px, 6vw, 56px);
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }
  .content-page .big-center p {
    max-width: 440px;
    margin: 0 auto 32px;
    color: var(--fumee);
  }
  .content-page .big-center .home-link {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .content-page .big-center .home-link:hover {
    color: var(--craie);
    border-color: var(--craie);
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    opacity: 0.7;
  }
  footer a {
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  footer a:hover {
    color: var(--craie);
  }
  footer .footer-center {
    flex: 1;
    text-align: center;
  }

  @media (max-width: 640px) {
    body { padding: 20px; }
    footer { flex-direction: column; gap: 8px; }
    .status { margin-top: 48px; }
    .status::before,
    .status::after { display: none; }
    .page-title::before,
    .page-title::after { display: none; }
    .form-wrapper iframe { min-height: calc(100vh - 200px); }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
</head>
<body>
  <slot />
</body>
</html>
