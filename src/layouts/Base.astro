---
interface Props {
  title: string;
  lang: 'fr' | 'en';
  theme?: 'dark' | 'light';
}
const { title, lang, theme = 'dark' } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} data-theme={theme}>
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="theme-color" content={theme === 'light' ? '#fafaf7' : '#0f0f0f'} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<style is:global>
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa25L7SUc.woff2) format('woff2');
    unicode-range: U+0100-02BA,U+02BD-02C5,U+02C7-02CC,U+02CE-02D7,U+02DD-02FF,U+0304,U+0308,U+0329,U+1D00-1DBF,U+1E00-1E9F,U+1EF2-1EFF,U+2020,U+20A0-20AB,U+20AD-20C0,U+2113,U+2C60-2C7F,U+A720-A7FF;
  }
  @font-face {
    font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap;
    src: url(https://fonts.gstatic.com/s/inter/v20/UcC73FwrK3iLTeHuS_nVMrMxCp50SjIa1ZL7.woff2) format('woff2');
    unicode-range: U+0000-00FF,U+0131,U+0152-0153,U+02BB-02BC,U+02C6,U+02DA,U+02DC,U+0304,U+0308,U+0329,U+2000-206F,U+20AC,U+2122,U+2191,U+2193,U+2212,U+2215,U+FEFF,U+FFFD;
  }

  :root {
    --charbon: #0f0f0f;
    --craie:   #f4f1ec;
    --cuivre:  #b66a3e;
    --fumee:   #8a8680;
    --line:    rgba(244, 241, 236, 0.12);
  }
  :root[data-theme="light"] {
    --charbon: #fafaf7;
    --craie:   #1a1a1a;
    --fumee:   #6b6760;
    --line:    rgba(15, 15, 15, 0.12);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--charbon);
    color: var(--craie);
    font-family: "Inter", "Helvetica Neue", -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 32px;
    animation: pageIn 1.2s ease-out both;
  }

  @keyframes pageIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @keyframes wordmarkIn {
    from { opacity: 0; letter-spacing: 0.5em; }
    to   { opacity: 1; letter-spacing: 0.22em; }
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Header ── */
  .corner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .corner-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
  }
  .corner-left .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cuivre);
  }
  .corner-right {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  /* ── Lang switcher ── */
  .lang-switcher {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .lang-switcher a {
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .lang-switcher a:hover { color: var(--craie); }
  .lang-active { color: var(--craie); }
  .lang-sep { color: var(--fumee); opacity: 0.35; }

  .back {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .back:hover { color: var(--craie); }

  /* ── Main ── */
  main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 40px 16px;
  }
  main.centered {
    justify-content: center;
    text-align: center;
  }
  main.spread {
    justify-content: space-between;
    text-align: center;
    padding-top: 32px;
    padding-bottom: 32px;
  }
  main.spread .cta,
  main.spread .contact {
    margin-top: 0;
  }
  .home-top {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Page d'accueil ── */
  .wordmark {
    font-weight: 700;
    letter-spacing: 0.22em;
    font-size: clamp(56px, 14vw, 148px);
    line-height: 1;
    color: var(--craie);
    animation: wordmarkIn 1.4s 0.2s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  .surligne {
    margin-top: 22px;
    font-size: clamp(10px, 1.2vw, 12px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.8s ease-out both;
  }
  .rule {
    display: inline-block;
    width: 48px;
    height: 1px;
    background: var(--cuivre);
    margin: 0 14px;
    vertical-align: middle;
  }
  .status {
    margin-top: 72px;
    font-size: clamp(11px, 1.2vw, 13px);
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 1.1s ease-out both;
  }
  .status::before,
  .status::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }
  .contact {
    margin-top: 40px;
    font-size: clamp(12px, 1.4vw, 14px);
    color: var(--fumee);
    letter-spacing: 0.04em;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .contact .label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 12px;
    opacity: 0.7;
  }
  .contact a {
    color: var(--craie);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    letter-spacing: 0.04em;
    transition: color 0.25s ease, border-color 0.25s ease;
    font-size: clamp(14px, 1.6vw, 16px);
    font-weight: 400;
  }
  .contact a:hover,
  .contact a:focus {
    color: var(--cuivre);
    border-color: var(--cuivre);
    outline: none;
  }

  /* ── Page sondage ── */
  .page-title {
    font-size: clamp(11px, 1.2vw, 13px);
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .page-title::before,
  .page-title::after {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--line);
    vertical-align: middle;
    margin: 0 14px;
  }
  .page-sub {
    margin-top: 10px;
    font-size: clamp(10px, 1.2vw, 11px);
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--fumee);
    animation: fadeUp 1.2s 0.5s ease-out both;
  }
  .form-wrapper {
    margin-top: 24px;
    flex: 1;
    width: 100%;
    max-width: 860px;
    border: 1px solid var(--line);
    animation: fadeUp 1.2s 0.7s ease-out both;
    display: flex;
    flex-direction: column;
  }
  .form-wrapper iframe {
    display: block;
    width: 100%;
    flex: 1;
    min-height: calc(100vh - 220px);
    border: none;
    background: var(--charbon);
  }
  .form-link {
    margin-top: 20px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    animation: fadeUp 1.2s 0.9s ease-out both;
  }
  .form-link a {
    color: var(--fumee);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 2px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .form-link a:hover {
    color: var(--cuivre);
    border-color: var(--cuivre);
  }

  /* ── Survey CTA (home) ── */
  .cta {
    margin-top: 56px;
    text-align: center;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .cta .label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 10px;
    opacity: 0.7;
  }
  .cta-prompt {
    font-size: 13px;
    line-height: 1.5;
    color: var(--craie);
    margin: 0 auto 22px;
    max-width: 360px;
  }
  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    border: 1px solid var(--line);
    color: var(--craie);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .cta-button:hover,
  .cta-button:focus-visible {
    border-color: var(--cuivre);
    color: var(--cuivre);
    outline: none;
  }
  .cta-arrow {
    font-size: 14px;
    transition: transform 0.25s ease;
  }
  .cta-button:hover .cta-arrow,
  .cta-button:focus-visible .cta-arrow {
    transform: translateX(3px);
  }

  /* ── Newsletter ── */
  .newsletter {
    margin-top: 56px;
    width: 100%;
    max-width: 420px;
    animation: fadeUp 1.2s 1.4s ease-out both;
  }
  .nl-heading {
    text-align: center;
    margin-bottom: 20px;
  }
  .nl-label {
    display: block;
    font-size: 10px;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 6px;
  }
  .nl-prompt {
    display: block;
    font-size: 13px;
    color: var(--craie);
    letter-spacing: 0.02em;
  }
  .nl-input-group {
    display: flex;
    align-items: stretch;
    border-bottom: 1px solid var(--line);
    transition: border-color 0.25s ease;
  }
  .nl-input-group:focus-within {
    border-bottom-color: var(--craie);
  }
  .nl-input-group input[type=email] {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--craie);
    font-family: inherit;
    font-size: 14px;
    padding: 12px 0;
    letter-spacing: 0.02em;
    min-width: 0;
  }
  .nl-input-group input[type=email]::placeholder {
    color: var(--fumee);
    opacity: 0.55;
  }
  .nl-input-group button {
    display: flex;
    align-items: center;
    gap: 10px;
    background: transparent;
    border: none;
    color: var(--craie);
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 12px 0 12px 14px;
    transition: color 0.25s ease;
  }
  .nl-input-group button:hover:not(:disabled),
  .nl-input-group button:focus-visible:not(:disabled) {
    color: var(--cuivre);
    outline: none;
  }
  .nl-input-group button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }
  .nl-arrow {
    font-size: 14px;
    transition: transform 0.25s ease;
  }
  .nl-input-group button:hover:not(:disabled) .nl-arrow {
    transform: translateX(3px);
  }
  .nl-consent {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 16px;
    font-size: 11px;
    line-height: 1.55;
    color: var(--fumee);
    text-align: left;
    cursor: pointer;
    letter-spacing: 0.01em;
  }
  .nl-consent input[type=checkbox] {
    margin-top: 3px;
    accent-color: var(--cuivre);
    flex-shrink: 0;
    cursor: pointer;
  }
  .nl-consent a {
    color: var(--fumee);
    text-decoration: underline;
    text-decoration-color: var(--line);
    text-underline-offset: 2px;
    transition: color 0.25s ease, text-decoration-color 0.25s ease;
  }
  .nl-consent a:hover,
  .nl-consent a:focus-visible {
    color: var(--craie);
    text-decoration-color: var(--craie);
  }
  .nl-error {
    margin-top: 14px;
    font-size: 11px;
    line-height: 1.5;
    color: var(--cuivre);
    text-align: center;
    letter-spacing: 0.02em;
  }
  .nl-success {
    text-align: center;
    padding: 24px 0 8px;
  }
  .nl-success-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    margin-bottom: 10px;
  }
  .nl-success-body {
    font-size: 13px;
    line-height: 1.6;
    color: var(--fumee);
    max-width: 340px;
    margin: 0 auto;
  }

  /* ── Page contenu (merci, confidentialité) ── */
  .content-page {
    max-width: 680px;
    width: 100%;
    margin: 0 auto;
    padding: 20px 0;
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .content-page h1 {
    font-size: clamp(22px, 3vw, 30px);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--craie);
    margin-bottom: 8px;
  }
  .content-page .subtitle {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 40px;
  }
  .content-page h2 {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--craie);
    margin: 32px 0 12px;
  }
  .content-page p,
  .content-page li {
    font-size: 14px;
    line-height: 1.7;
    color: var(--craie);
    margin-bottom: 12px;
  }
  .content-page ul,
  .content-page ol {
    padding-left: 22px;
    margin-bottom: 16px;
  }
  .content-page ol li {
    padding-left: 4px;
  }
  .content-page a {
    color: var(--cuivre);
    text-decoration: underline;
    text-decoration-color: rgba(182, 106, 62, 0.4);
    text-underline-offset: 2px;
  }
  .content-page a:hover {
    text-decoration-color: var(--cuivre);
  }
  .content-page .big-center {
    text-align: center;
    padding: 80px 0 40px;
  }
  .content-page .big-center h1 {
    font-size: clamp(36px, 6vw, 56px);
    letter-spacing: 0.08em;
    margin-bottom: 20px;
  }
  .content-page .big-center p {
    max-width: 440px;
    margin: 0 auto 32px;
    color: var(--fumee);
  }
  .content-page .big-center .home-link {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .content-page .big-center .home-link:hover {
    color: var(--craie);
    border-color: var(--craie);
  }

  /* ── Admin pages ── */
  .admin-page {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 8px 0 48px;
    animation: fadeUp 1.2s 0.2s ease-out both;
  }
  .admin-user {
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--fumee);
    font-family: 'Menlo', 'Consolas', monospace;
  }
  .admin-section {
    margin-bottom: 56px;
  }
  .admin-title {
    font-size: clamp(20px, 2.6vw, 28px);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--craie);
    margin-bottom: 28px;
  }
  .admin-subtitle {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--fumee);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .admin-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }
  .stat {
    padding: 24px 20px;
    border: 1px solid var(--line);
    background: transparent;
  }
  .stat-value {
    font-size: 42px;
    font-weight: 700;
    letter-spacing: 0.01em;
    color: var(--craie);
    line-height: 1;
    margin-bottom: 10px;
  }
  .stat-label {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
  }
  .admin-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .admin-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    border: 1px solid var(--line);
    color: var(--craie);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.25s ease, color 0.25s ease, background 0.25s ease;
  }
  .admin-button:hover,
  .admin-button:focus-visible {
    border-color: var(--cuivre);
    color: var(--cuivre);
    outline: none;
  }
  .admin-empty {
    color: var(--fumee);
    font-size: 13px;
    padding: 20px 0;
  }
  .admin-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
  }
  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
  }
  .admin-table th {
    text-align: left;
    padding: 12px 14px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fumee);
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }
  .admin-table td {
    padding: 12px 14px;
    color: var(--craie);
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }
  .admin-table tbody tr:last-child td {
    border-bottom: none;
  }
  .admin-table tbody tr:hover td {
    color: var(--cuivre);
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    flex-wrap: wrap;
  }
  .pag-btn {
    display: inline-flex;
    align-items: center;
    padding: 8px 14px;
    border: 1px solid var(--line);
    color: var(--craie);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .pag-btn:hover:not(.is-disabled) {
    border-color: var(--cuivre);
    color: var(--cuivre);
  }
  .pag-btn.is-disabled {
    opacity: 0.35;
    pointer-events: none;
  }
  .pag-info {
    font-size: 11px;
    color: var(--fumee);
    margin: 0 12px;
    letter-spacing: 0.04em;
  }

  /* Clickable table rows */
  .admin-table.is-clickable tbody tr {
    cursor: pointer;
  }
  .admin-table.is-clickable tbody tr:hover td {
    color: var(--cuivre);
    background: rgba(182, 106, 62, 0.04);
  }
  .td-comment {
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    color: var(--fumee);
    font-style: italic;
    font-size: 11px;
  }

  /* Detail page */
  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-link:hover { color: var(--craie); }

  .detail-list {
    margin: 0;
    border-top: 1px solid var(--line);
  }
  .detail-row {
    display: grid;
    grid-template-columns: minmax(180px, 260px) 1fr;
    gap: 24px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
    font-size: 13px;
    align-items: baseline;
  }
  .detail-row dt {
    color: var(--fumee);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .detail-row dd {
    margin: 0;
    color: var(--craie);
    line-height: 1.5;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
  }
  .detail-row dd strong {
    font-weight: 700;
  }
  .detail-tag {
    display: inline-block;
    padding: 3px 10px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .detail-tag.tone-essential {
    background: var(--cuivre);
    color: var(--charbon);
    border-color: var(--cuivre);
  }
  .detail-tag.tone-interesting {
    background: rgba(182, 106, 62, 0.15);
    color: var(--cuivre);
    border-color: rgba(182, 106, 62, 0.4);
  }
  .detail-tag.tone-low {
    color: var(--fumee);
  }
  .detail-tag.tone-none {
    color: var(--fumee);
    opacity: 0.6;
  }
  .detail-quote {
    margin: 0;
    padding: 12px 16px;
    background: rgba(15, 15, 15, 0.04);
    border-left: 3px solid var(--cuivre);
    font-style: italic;
    color: var(--craie);
    line-height: 1.6;
    width: 100%;
  }
  .muted { color: var(--fumee); font-style: italic; }

  @media (max-width: 640px) {
    .detail-row { grid-template-columns: 1fr; gap: 4px; }
    .pagination { justify-content: center; }
  }

  /* Admin nav (sondage / concours) */
  .admin-nav {
    display: flex;
    gap: 28px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--line);
  }
  .admin-nav a {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    padding-bottom: 8px;
    margin-bottom: -13px;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .admin-nav a:hover { color: var(--craie); }
  .admin-nav a.is-active {
    color: var(--craie);
    border-bottom-color: var(--cuivre);
  }

  /* Inline form (used for danger buttons) */
  .inline-form {
    display: inline-block;
    margin: 0;
  }
  .admin-button.is-danger {
    border-color: rgba(196, 80, 80, 0.5);
    color: #c45050;
    background: transparent;
    cursor: pointer;
    font-family: inherit;
  }
  .admin-button.is-danger:hover,
  .admin-button.is-danger:focus-visible {
    border-color: #c45050;
    color: #fff;
    background: #c45050;
    outline: none;
  }

  /* Mode toggle (admin) */
  .mode-toggle {
    display: inline-flex;
    margin: 0 0 24px;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 999px;
    gap: 4px;
  }
  .mode-toggle a {
    padding: 7px 18px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fumee);
    text-decoration: none;
    border-radius: 999px;
    transition: color 0.2s ease, background 0.2s ease;
  }
  .mode-toggle a:hover { color: var(--craie); }
  .mode-toggle a.is-active {
    background: var(--craie);
    color: var(--charbon);
  }
  .test-banner {
    margin: 0 0 32px;
    padding: 14px 20px;
    border: 1px solid var(--cuivre);
    border-left-width: 4px;
    background: rgba(182, 106, 62, 0.06);
    color: var(--craie);
    font-size: 13px;
    line-height: 1.5;
  }
  .test-banner strong {
    color: var(--cuivre);
    letter-spacing: 0.04em;
  }

  /* Distribution charts */
  .admin-meta {
    font-size: 13px;
    color: var(--fumee);
    margin-bottom: 20px;
    line-height: 1.5;
  }
  .admin-meta strong {
    color: var(--craie);
    font-weight: 600;
  }
  .dist-group {
    margin-bottom: 32px;
  }
  .dist-group:last-child {
    margin-bottom: 0;
  }
  .dist-group-title {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fumee);
    margin: 0 0 14px;
  }
  .dist {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .dist-row {
    display: grid;
    grid-template-columns: minmax(140px, 240px) 1fr 110px;
    align-items: center;
    gap: 14px;
    font-size: 12px;
    padding: 4px 0;
  }
  .dist-label {
    color: var(--craie);
    line-height: 1.4;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .dist-bar {
    height: 8px;
    background: var(--line);
    border-radius: 2px;
    overflow: hidden;
  }
  .dist-fill {
    height: 100%;
    background: var(--cuivre);
    transition: width 0.4s ease;
  }
  .dist-count {
    color: var(--craie);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    text-align: right;
  }
  .dist-pct {
    color: var(--fumee);
    font-weight: 400;
    margin-left: 4px;
  }
  .dist-row.is-target .dist-fill {
    background: var(--cuivre);
    box-shadow: 0 0 0 1px var(--cuivre);
  }
  .target-tag {
    display: inline-block;
    padding: 2px 8px;
    background: var(--cuivre);
    color: var(--charbon);
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border-radius: 2px;
  }

  @media (max-width: 640px) {
    .dist-row {
      grid-template-columns: 1fr;
      gap: 4px;
      padding: 8px 0;
      border-bottom: 1px solid var(--line);
    }
    .dist-count { text-align: left; }
  }

  /* ── Footer ── */
  footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee);
    opacity: 0.7;
  }
  footer a {
    color: var(--fumee);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  footer a:hover {
    color: var(--craie);
  }
  footer .footer-center {
    flex: 1;
    text-align: center;
  }

  /* ── Survey ── */
  .survey {
    max-width: 760px;
    width: 100%;
    margin: 0 auto;
    padding: 8px 0 48px;
    animation: fadeUp 1.2s 0.3s ease-out both;
  }
  .survey-intro {
    text-align: center;
    margin-bottom: 56px;
    padding: 0 8px;
  }
  .survey-title {
    font-size: clamp(22px, 3.2vw, 32px);
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.25;
    color: var(--craie);
    margin-bottom: 24px;
  }
  .survey-intro p {
    font-size: 14px;
    line-height: 1.7;
    color: var(--craie);
    max-width: 560px;
    margin: 0 auto 14px;
  }
  .survey-signature {
    font-style: italic;
    color: var(--fumee) !important;
    margin-top: 22px !important;
  }
  .survey-time {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 20px !important;
    padding: 6px 16px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 11px !important;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--fumee) !important;
  }
  .survey-time .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--cuivre);
  }

  .survey-form {
    margin-top: 0;
  }
  .survey-required-note {
    font-size: 11px;
    color: var(--fumee);
    letter-spacing: 0.02em;
    text-align: center;
    margin-bottom: 48px;
  }
  .survey-section {
    border: none;
    padding: 0;
    margin: 0 0 56px;
  }
  .survey-section legend {
    display: block;
    width: 100%;
    padding: 0 0 24px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--line);
  }
  .survey-section-title {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
  }
  .survey-section-intro {
    display: block;
    margin-top: 10px;
    font-size: 13px;
    line-height: 1.5;
    color: var(--fumee);
    letter-spacing: 0.01em;
  }
  .survey-section-intro strong {
    color: rgba(244, 241, 236, 0.9);
    font-weight: 500;
  }

  /* Questions */
  .q {
    margin-bottom: 44px;
    padding-left: 16px;
    border-left: 2px solid var(--line);
    transition: border-color 0.25s ease;
  }
  .q:focus-within {
    border-left-color: var(--cuivre);
  }
  .q-label {
    display: flex;
    gap: 14px;
    font-size: 16px;
    font-weight: 500;
    line-height: 1.45;
    color: var(--craie);
    margin-bottom: 20px;
  }
  .q-num {
    color: var(--cuivre);
    font-weight: 700;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 36px;
  }
  .q-required {
    color: var(--cuivre);
    margin-left: 4px;
    font-weight: 400;
  }
  .q-hint {
    margin: -10px 0 16px 50px;
    font-size: 12px;
    color: var(--fumee);
    letter-spacing: 0.01em;
    font-style: italic;
  }
  .q-options {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-left: 50px;
  }

  /* Custom radio & checkbox */
  .opt {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    padding: 6px 0;
    cursor: pointer;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.5;
    color: rgba(244, 241, 236, 0.78);
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }
  .opt:hover { color: var(--craie); }
  .opt:has(input:checked) { color: var(--craie); }
  .opt input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .opt-custom {
    flex-shrink: 0;
    width: 16px;
    height: 16px;
    border: 1px solid var(--fumee);
    border-radius: 50%;
    margin-top: 3px;
    position: relative;
    transition: border-color 0.2s ease;
  }
  .opt-custom.opt-check {
    border-radius: 3px;
  }
  .opt:hover .opt-custom { border-color: var(--cuivre); }
  .opt input:checked + .opt-custom {
    border-color: var(--cuivre);
  }
  .opt input:checked + .opt-custom::after {
    content: '';
    position: absolute;
    inset: 3px;
    background: var(--cuivre);
    border-radius: 50%;
  }
  .opt input:checked + .opt-custom.opt-check::after {
    inset: 2px;
    border-radius: 1px;
  }
  .opt input:focus-visible + .opt-custom {
    outline: 2px solid var(--cuivre);
    outline-offset: 2px;
  }

  /* Scale (Q6) */
  .q-scale {
    margin-left: 50px;
  }
  .scale-track {
    display: grid;
    grid-template-columns: repeat(10, 1fr);
    gap: 4px;
    margin-bottom: 10px;
  }
  .scale-cell {
    cursor: pointer;
  }
  .scale-cell input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .scale-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    border: 1px solid var(--line);
    border-radius: 4px;
    font-size: 13px;
    color: var(--fumee);
    transition: all 0.2s ease;
  }
  .scale-cell:hover .scale-dot {
    border-color: var(--cuivre);
    color: var(--craie);
  }
  .scale-cell input:checked + .scale-dot {
    background: var(--cuivre);
    border-color: var(--cuivre);
    color: var(--charbon);
    font-weight: 700;
  }
  .scale-labels {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: var(--fumee);
    letter-spacing: 0.02em;
  }

  /* Textarea */
  .q textarea {
    margin-left: 50px;
    width: calc(100% - 50px);
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 2px;
    padding: 12px 14px;
    color: var(--craie);
    font-family: inherit;
    font-size: 13px;
    line-height: 1.6;
    resize: vertical;
    transition: border-color 0.2s ease;
  }
  .q textarea:focus {
    outline: none;
    border-color: var(--cuivre);
  }
  .q textarea::placeholder {
    color: var(--fumee);
    opacity: 0.55;
  }

  /* Matrix (Q14) */
  .q-matrix {
    margin-left: 50px;
    overflow-x: auto;
  }
  .matrix-grid {
    display: grid;
    grid-template-columns: minmax(220px, 2fr) repeat(var(--cols), minmax(90px, 1fr));
    min-width: 580px;
  }
  .matrix-header {
    border-bottom: 1px solid var(--line);
  }
  .matrix-col-label {
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fumee);
    text-align: center;
    padding: 0 6px 14px;
    border-bottom: 1px solid var(--line);
  }
  .matrix-row-label {
    display: flex;
    align-items: center;
    padding: 14px 12px 14px 0;
    font-size: 13px;
    line-height: 1.5;
    color: rgba(244, 241, 236, 0.82);
    border-bottom: 1px solid var(--line);
  }
  .matrix-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 14px 6px;
    cursor: pointer;
    border-bottom: 1px solid var(--line);
    transition: background 0.15s ease;
  }
  .matrix-cell:hover { background: rgba(182, 106, 62, 0.06); }
  .matrix-cell input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .matrix-dot {
    width: 16px;
    height: 16px;
    border: 1px solid var(--fumee);
    border-radius: 50%;
    transition: all 0.2s ease;
  }
  .matrix-cell:hover .matrix-dot { border-color: var(--cuivre); }
  .matrix-cell input:checked + .matrix-dot {
    border-color: var(--cuivre);
    background: var(--cuivre);
    box-shadow: inset 0 0 0 2px var(--charbon);
  }

  /* Survey newsletter opt-in block */
  .survey-newsletter {
    margin: 56px 0 0;
    padding: 28px 24px;
    border: 1px solid var(--line);
    border-radius: 2px;
  }
  .survey-newsletter-head {
    margin-bottom: 18px;
  }
  .survey-newsletter-title {
    display: block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--craie);
    margin-bottom: 8px;
  }
  .survey-newsletter-hint {
    font-size: 12px;
    line-height: 1.55;
    color: var(--fumee);
    margin: 0;
  }
  .survey-nl-toggle {
    padding: 10px 0;
  }
  .survey-nl-fields {
    margin-top: 16px;
    padding-left: 28px;
  }
  .survey-nl-fields .nl-input-group {
    max-width: 420px;
  }
  .survey-nl-consent {
    margin-top: 14px;
  }

  /* Contest section */
  .survey-contest-fields {
    margin-top: 16px;
    padding-left: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 420px;
  }
  .contest-row input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--line);
    color: var(--craie);
    font-family: inherit;
    font-size: 14px;
    padding: 10px 0;
    letter-spacing: 0.02em;
    outline: none;
    transition: border-color 0.25s ease;
  }
  .contest-row input:focus {
    border-bottom-color: var(--craie);
  }
  .contest-row input::placeholder {
    color: var(--fumee);
    opacity: 0.55;
  }

  /* Survey submit */
  .survey-error {
    margin: 0 0 16px;
    font-size: 12px;
    color: var(--cuivre);
    text-align: center;
  }
  .survey-submit-row {
    text-align: center;
    margin-top: 48px;
  }
  .survey-submit {
    background: var(--craie);
    color: var(--charbon);
    border: none;
    padding: 16px 40px;
    font-family: inherit;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .survey-submit:hover:not(:disabled) {
    background: var(--cuivre);
    color: var(--craie);
  }
  .survey-submit:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (max-width: 640px) {
    body { padding: 20px; }
    footer { flex-direction: column; gap: 8px; }
    .status { margin-top: 48px; }
    .status::before,
    .status::after { display: none; }
    .page-title::before,
    .page-title::after { display: none; }
    .form-wrapper iframe { min-height: calc(100vh - 200px); }

    /* Survey mobile */
    .q { padding-left: 12px; }
    .q-label { gap: 10px; font-size: 15px; }
    .q-num { min-width: 28px; font-size: 13px; }
    .q-hint { margin-left: 38px; }
    .q-options,
    .q-scale,
    .q-matrix,
    .q textarea { margin-left: 0; }
    .q textarea { width: 100%; }
    .scale-track { gap: 2px; }
    .scale-dot { height: 38px; font-size: 11px; }
    .survey-newsletter { padding: 22px 18px; }
    .survey-nl-fields { padding-left: 0; }
    .survey-contest-fields { padding-left: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
